rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasCurrentUserDoc() {
      return signedIn() && exists(currentUserDoc());
    }

    // Correctif (chantier "durcissement sans Cloud Functions", plan
    // Firebase Spark/gratuit) : suspendre un compte (users/{uid}.status)
    // ne révoquait jusqu'ici AUCUNE session Firebase Auth déjà active —
    // le SDK rafraîchit son jeton silencieusement, et les fonctions de
    // capacité ci-dessous ne vérifiaient que le RÔLE, jamais le statut
    // du compte agissant. Un professionnel suspendu gardait donc tous
    // ses droits Firestore jusqu'à expiration naturelle de sa session.
    // Une vraie révocation de session (admin.auth().revokeRefreshTokens)
    // nécessite l'Admin SDK, donc une Cloud Function, donc le plan
    // Blaze — hors de portée tant que le projet reste sur Spark.
    // accountStatusOk() referme l'accès aux DONNÉES (Firestore, le
    // seul point sensible ici) en temps quasi réel : dès que le champ
    // status bascule, la toute prochaine requête est refusée, sans
    // attendre l'expiration du token. Ce n'est pas l'équivalent d'une
    // vraie révocation de session Auth, mais ça ferme concrètement
    // l'accès aux données — nuance à ne jamais présenter comme
    // équivalente dans la documentation. Défaut permissif si le champ
    // status est absent (comptes existants non encore dotés d'un
    // statut individuel — rétro-compatibilité, même logique que
    // subscriptionStatus()/hospitalSubscriptionOk() plus bas).
    function accountStatusOk() {
      return !hasCurrentUserDoc() ||
        get(currentUserDoc()).data.get('status', 'approved') in ['approved', 'active'];
    }

    // NOTE — bug corrigé pendant ce chantier (découvert en écrivant les
    // tests d'émulateur, tests/firestore-rules/) : un accès direct en
    // notation pointée à un custom claim jamais explicitement posé
    // (request.auth.token.role / .admin) lève une erreur d'évaluation
    // ("Property X is undefined") plutôt que de retourner null, quand
    // le token ne porte STRICTEMENT AUCUNE valeur pour cette clé — ce
    // qui n'arrive jamais avec un vrai jeton Firebase Auth de
    // production (toujours "complet"), mais arrive bel et bien avec un
    // compte qui n'a reçu aucun custom claim (le cas courant : la
    // plupart des comptes n'ont pas de claim 'role', le rôle vit dans
    // users/{uid}). Le déni en résultait presque toujours (Firestore
    // refuse par défaut sur exception), mais silencieusement et de
    // façon fragile. .get(key, défaut) sur le token (une Map) est la
    // façon robuste de lire un champ optionnel sans jamais lever.
    function currentRoleIs(role) {
      return signedIn() && accountStatusOk() && (
        request.auth.token.get('role', null) == role ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == role)
      );
    }

    function isAdmin() {
      return signedIn() && accountStatusOk() && (
        request.auth.token.get('admin', false) == true ||
        request.auth.token.get('role', null) == 'admin' ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == 'admin')
      );
    }

    /* ── CAPACITÉS PAR RÔLE (miroir serveur de HospitalCapabilities) ──
       Le rôle est lu depuis users/{uid} (currentRoleIs) ou le token :
       il est VÉRIFIÉ, non déclaré par le client. Ces helpers permettent
       aux règles de refuser elles-mêmes une action que le rôle ne
       permet pas — même si le client contourne le JavaScript.
       Note : admin_hospital et lab n'ont pas de rôle mobile ; ils
       apparaissent ici pour le desktop. La source reste users/{uid}. */
    function hasRole(role) {
      return signedIn() && accountStatusOk() && (
        request.auth.token.get('role', null) == role ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == role)
      );
    }
    // 'hospital' = compte propriétaire d'un établissement (créé à
    // l'inscription desktop). Il n'écrit PAS de données médicales
    // lui-même : chaque agent s'authentifie avec SON compte personnel,
    // et c'est SON rôle réel (doctor/nurse/lab/reception) que les
    // capacités ci-dessous vérifient. Le serveur distingue donc les
    // agents entre eux.
    // Décider/valider un acte médical : médecin (ou admin plateforme/hôpital)
    function canDecideMedical() {
      return isAdmin() || hasRole('doctor') || hasRole('admin_hospital');
    }
    // Prescrire : strictement médecin
    function canPrescribe() {
      return isAdmin() || hasRole('doctor');
    }
    // Décider un transfert médical : médecin (ou admin hôpital)
    function canDecideTransfer() {
      return isAdmin() || hasRole('doctor') || hasRole('admin_hospital');
    }
    // Admettre / sortir / gérer lits : personnel de soins
    function canManageCare() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') || hasRole('admin_hospital');
    }
    // Saisir un résultat de labo : laborantin (ou médecin/admin)
    function canEnterLabResult() {
      return isAdmin() || hasRole('lab') || hasRole('doctor') || hasRole('admin_hospital');
    }
    // Enregistrer une arrivée / créer patient à l'accueil : réception + soignants
    function canRegisterPatient() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') ||
             hasRole('reception') || hasRole('admin_hospital');
    }

    /* ── Abonnement établissement (contrat mobile ↔ desktop) ──
       Aucun document subscriptions/{hospitalId} => traité comme
       "active" par défaut (rétro-compatibilité : ne bloque pas les
       établissements existants tant que l'abonnement n'a pas été
       explicitement configuré). */
    function subscriptionDoc(hospitalId) {
      return /databases/$(database)/documents/subscriptions/$(hospitalId);
    }
    function subscriptionStatus(hospitalId) {
      return hospitalId != null && exists(subscriptionDoc(hospitalId))
        ? get(subscriptionDoc(hospitalId)).data.status
        : 'active';
    }
    function hospitalSubscriptionOk(hospitalId) {
      return subscriptionStatus(hospitalId) in ['active', 'grace_period'];
    }
    // Utilisée telle quelle uniquement pour /patients : la création
    // de patient reste bloquée par abonnement expiré/suspendu quelle
    // que soit la plateforme (desktop ET mobile/PWA — confirmé
    // explicitement : c'est la seule action que le mobile bloque
    // aussi).
    function hospitalCanWrite(hospitalId) {
      return hospitalSubscriptionOk(hospitalId);
    }
    // Utilisée pour consultations/prescriptions/labRequests/
    // labResults/appointments/messages/hospitalMembers : le mobile/PWA
    // reste autorisé à écrire même hôpital expiré (le soin courant ne
    // doit jamais être coupé pour une facture desktop impayée) ; seul
    // le desktop est réellement bloqué. Le signal sourceDevice vient
    // du document envoyé par le client (voir note de risque résiduel
    // dans le rapport final : un client malveillant pourrait usurper
    // ce champ — accepté comme limite connue, pas de nouveau système
    // d'auth introduit pour ce chantier).
    // ⚠️ LIMITE DE SÉCURITÉ CONNUE — sourceDevice est DÉCLARÉ par le
    // client : un client desktop peut envoyer sourceDevice:'mobile'
    // pour contourner le blocage d'abonnement. Fermer réellement cette
    // faille exige un custom claim posé côté serveur (Cloud Function),
    // que les règles liraient via request.auth.token.deviceType au lieu
    // du champ du document. Tant que ce backend n'existe pas, le gating
    // desktop reste dissuasif mais non infalsifiable. NE PAS présenter
    // ce contrôle comme une sécurité forte.
    // Migration future : remplacer `deviceValue` par
    // `request.auth.token.deviceType` ici, sans toucher aux appelants.
    function hospitalCanWriteFromDevice(hospitalId, deviceValue) {
      return hospitalSubscriptionOk(hospitalId) || deviceValue != 'desktop';
    }
    // Le code applicatif écrit establishmentId (parfois hospital_id
    // en repli historique) — jamais un champ "hospitalId" littéral.
    // Ce helper évite de répéter ce repli dans chaque règle.
    // NOTE — bug réel corrigé pendant ce chantier (découvert en testant
    // hospitalMembers avec l'émulateur) : accès direct en notation
    // pointée à un champ que le document ne porte PAS du tout (ex :
    // hospitalMembers écrit hospitalId mais pas establishmentId) lève
    // une erreur d'évaluation ("Property X is undefined") au lieu de
    // retourner null — même famille que le bug déjà corrigé sur
    // request.auth.token. .get(clé, défaut) sur une map lit un champ
    // optionnel sans jamais lever.
    function resolveHospitalId(data) {
      return data.get('establishmentId', null) != null ? data.get('establishmentId', null)
        : (data.get('hospital_id', null) != null ? data.get('hospital_id', null)
        : (data.get('hospitalId', null) != null ? data.get('hospitalId', null) : data.get('fromHospitalId', null)));
    }

    /* ── PARTIE E — isolation par établissement (serveur) ──
       hospitalMembers/{hospitalId}_{uid} est un document PLAT écrit par
       l'application (js/hospitals_registry.js) en miroir de
       establishments.staff[] — une règle Firestore ne peut pas tester
       efficacement l'appartenance à un tableau d'objets, d'où ce doc
       à clé déterministe. isHospitalMember/belongsToSameEstablishment
       s'ajoutent en OR aux vérifications existantes (auteur direct via
       doctorCanRead/nurseCanRead/ownsPatientData) — jamais en
       remplacement : un médecin auteur direct garde toujours accès même
       sans document hospitalMembers (compte créé avant ce chantier).
       IMPORTANT (clarification client) : ce mécanisme ne dépend JAMAIS
       de mc_consents — l'accès de l'établissement CRÉATEUR de la fiche
       ne requiert aucun consentement patient ; le consentement ne sert
       qu'aux accès EXTERNES (voir mc_consents plus bas). */
    function hospitalMemberDoc(hospitalId, uid) {
      return /databases/$(database)/documents/hospitalMembers/$(hospitalId + '_' + uid);
    }
    // Correctif (revue Codex sur PR "durcissement sans Cloud
    // Functions") : accountStatusOk() n'était injecté que dans
    // hasRole()/currentRoleIs()/isAdmin() — pas ici. Or isHospitalMember()
    // est le chemin d'accès de la quasi-totalité des collections
    // médicales (belongsToSameEstablishment) : un compte suspendu
    // (users/{uid}.status) dont le document hospitalMembers restait
    // "active" gardait donc tout son accès établissement, vidant la
    // protection de suspension de l'essentiel de sa substance.
    function isHospitalMember(hospitalId) {
      return signedIn() && accountStatusOk() && hospitalId != null &&
        exists(hospitalMemberDoc(hospitalId, request.auth.uid)) &&
        get(hospitalMemberDoc(hospitalId, request.auth.uid)).data.status == 'active';
    }
    function belongsToSameEstablishment(data) {
      return isHospitalMember(resolveHospitalId(data));
    }

    function ownsUid(uid) {
      return signedIn() && uid == request.auth.uid;
    }

    function uidIn(listValue) {
      return signedIn() && listValue is list && request.auth.uid in listValue;
    }

    // NOTE — même correctif que resolveHospitalId/currentRoleIs :
    // .get(clé, défaut) plutôt que l'accès pointé direct, qui lève une
    // erreur d'évaluation quand le document ne porte pas du tout ce
    // champ (constaté avec l'émulateur sur plusieurs collections où
    // tous les documents n'ont pas tous les mêmes champs optionnels).
    function ownsPatientData(data) {
      return signedIn() && (
        data.get('uid', null) == request.auth.uid ||
        data.get('patientUid', null) == request.auth.uid ||
        data.get('patient_uid', null) == request.auth.uid ||
        data.get('ownerUid', null) == request.auth.uid ||
        // PARTIE B — patient authentifié via Firebase Auth (PIN migré,
        // voir js/auth.js _createPatientFirebaseAuth/_signInPatientFirebaseAuth).
        // Le compte garde un uid stable 'PAT_'+id (adressage mc_accounts) ;
        // patientAuthUid porte l'uid Firebase réel. Clause tolérante :
        // aucun code client n'écrit encore ce champ sur la fiche patient
        // elle-même dans cette PR (nécessiterait un mécanisme de
        // revendication dédié, hors scope) — sans effet tant qu'absent,
        // prête pour une future écriture contrôlée.
        data.get('patientAuthUid', null) == request.auth.uid
      );
    }

    function doctorCanRead(data) {
      return currentRoleIs('doctor') && (
        data.get('created_by', null) == request.auth.uid ||
        data.get('doctorUid', null) == request.auth.uid ||
        data.get('doctor_uid', null) == request.auth.uid ||
        uidIn(data.get('doctorUids', [])) ||
        uidIn(data.get('authorizedDoctorUids', []))
      );
    }

    function nurseCanRead(data) {
      return currentRoleIs('nurse') && (
        data.get('nurseUid', null) == request.auth.uid ||
        data.get('nurse_uid', null) == request.auth.uid ||
        uidIn(data.get('nurseUids', [])) ||
        uidIn(data.get('authorizedNurseUids', []))
      );
    }

    function pharmacyCanReadPrescription(data) {
      return currentRoleIs('pharmacist') && (
        data.get('pharmacyUid', null) == request.auth.uid ||
        data.get('pharmacy_uid', null) == request.auth.uid ||
        data.get('receivedByPharmacyUid', null) == request.auth.uid ||
        uidIn(data.get('pharmacyUids', []))
      );
    }

    /* ── PARTIE D — consentements (mc_consents) ──
       js/access_control.js identifie un patient par patient_id (le
       numéro de fiche, ex "MC-2026-..."), pas par un uid Firebase —
       impossible à comparer directement à request.auth.uid. On résout
       donc l'uid Firebase réel du patient via mc_accounts/PAT_{patient_id}
       .authUid, posé de façon fiable à la création du compte (règle
       "create" de mc_accounts, non restreinte par auth — voir plus bas)
       une fois le PIN migré vers Firebase Authentication (PARTIE B).
       Limite assumée : un compte patient hérité pas encore migré
       (authUid absent) ne peut pas encore être vérifié ainsi côté
       règles — documenté dans le rapport final. */
    function patientAccountAuthUid(patientId) {
      return patientId != null &&
        exists(/databases/$(database)/documents/mc_accounts/$('PAT_' + patientId))
        ? get(/databases/$(database)/documents/mc_accounts/$('PAT_' + patientId)).data.authUid
        : null;
    }
    function isConcernedPatient(patientId) {
      return signedIn() && patientAccountAuthUid(patientId) == request.auth.uid;
    }

    /* ── Code d'accès hôpital (chantier séparé, suite à la revue de
       sécurité de la PR #1) ──
       Avant ce correctif, n'importe qui connaissant le numéro de fiche
       d'un patient pouvait créer mc_accounts/PAT_{id} avec SA PROPRE
       identité Firebase avant que le vrai patient ne s'inscrive,
       satisfaisant ensuite isConcernedPatient() à sa place (accès aux
       décisions de consentement/partage en tant que ce patient, et
       verrouillage définitif du vrai patient hors de son propre
       compte — mc_accounts.create refuse un doc déjà existant).
       mc_patients/{id}.firstAccessCode est généré par le personnel à
       la création de la fiche (js/db.js addPatient) et communiqué au
       patient hors ligne (papier, oralement) — jamais exposé par une
       règle de lecture. Le premier accès doit désormais fournir ce
       code, comparé ici au moment de la création du compte.
       Rétro-compatible : les fiches créées avant ce chantier n'ont pas
       ce champ, donc aucun code n'est exigé pour elles (défaut
       permissif, même logique que accountStatusOk()/
       hospitalSubscriptionOk()). */
    function patientFirstAccessOk(patientMcId, submittedCode) {
      return patientMcId == null ||
        !exists(/databases/$(database)/documents/mc_patients/$(patientMcId)) ||
        get(/databases/$(database)/documents/mc_patients/$(patientMcId)).data.get('firstAccessCode', null) == null ||
        get(/databases/$(database)/documents/mc_patients/$(patientMcId)).data.get('firstAccessCode', null) == submittedCode;
    }

    function canReadMedicalData(data) {
      return isAdmin() ||
        ownsPatientData(data) ||
        doctorCanRead(data) ||
        nurseCanRead(data);
    }

    function publicUserRole(role) {
      // 'hospital' : compte d'établissement (connexion desktop par
      // matricule). 'lab'/'reception' : agents hospitaliers desktop.
      // Tous auto-créés en statut 'pending', validés par l'admin
      // comme les autres inscriptions professionnelles.
      return role in ['patient', 'doctor', 'nurse', 'pharmacist', 'hospital', 'lab', 'reception'];
    }

    // PARTIE B — 'pin' ajouté : garde-fou contre toute réintroduction
    // future d'un PIN patient en clair (ou d'un hash local non salé/
    // faible) dans un document — Firebase Auth est désormais la seule
    // source de vérité pour le PIN (voir js/auth.js).
    function hasNoSecretFields(data) {
      return !data.keys().hasAny(['admin', 'password', 'passwordHash', 'pin']);
    }

    function visiblePharmacyProfile(data) {
      return data.role == 'pharmacist' &&
        data.isLocationVisible == true &&
        data.status in ['active', 'approved'];
    }

    function safeSelfUserCreate(uid) {
      return ownsUid(uid) &&
        request.resource.data.uid == uid &&
        publicUserRole(request.resource.data.role) &&
        request.resource.data.status == 'pending' &&
        hasNoSecretFields(request.resource.data);
    }

    function safeSelfUserUpdate(uid) {
      return ownsUid(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        hasNoSecretFields(request.resource.data);
    }

    match /users/{uid} {
      allow create: if isAdmin() || safeSelfUserCreate(uid);
      allow read: if isAdmin() ||
        ownsUid(uid) ||
        visiblePharmacyProfile(resource.data);
      allow update: if isAdmin() || safeSelfUserUpdate(uid);
      // Correctif (chantier "suppression de compte") : le propriétaire
      // peut désormais supprimer son propre document, en plus de
      // isAdmin() — première brique de la suppression de compte
      // self-service (js/auth.js Auth._confirmDeleteMyAccount).
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /patients/{patientId} {
      allow read: if canReadMedicalData(resource.data);
      // Création bloquée si abonnement expiré/suspendu — confirmé :
      // c'est la SEULE action que le mobile/PWA bloque aussi (voir
      // hospitalCanWrite, sans distinction de plateforme ici).
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse')) &&
         hospitalCanWrite(request.resource.data.establishmentId != null
           ? request.resource.data.establishmentId
           : request.resource.data.hospital_id));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data);
    }

    match /doctors/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'doctor' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /nurses/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'nurse' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /pharmacies/{uid} {
      allow read: if isAdmin() ||
        ownsUid(uid) ||
        (
          resource.data.isLocationVisible == true &&
          resource.data.status in ['active', 'approved']
        );
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'pharmacist' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /hospitals/{hospitalId} {
      allow read: if signedIn() && (
        resource.data.status in ['active', 'approved'] ||
        uidIn(resource.data.staffUids) ||
        resource.data.owner_uid == request.auth.uid ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    match /medical_records/{recordId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
      allow update, delete: if isAdmin() || doctorCanRead(resource.data);
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAdmin() ||
        ownsPatientData(resource.data) ||
        doctorCanRead(resource.data) ||
        pharmacyCanReadPrescription(resource.data);
      allow create: if isAdmin() ||
        (currentRoleIs('doctor') &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // La pharmacie ciblée peut toujours mettre à jour le statut
      // même abonnement expiré/suspendu (une ordonnance déjà envoyée
      // doit pouvoir être honorée) ; le médecin auteur reste soumis
      // à la même règle desktop/mobile que la création.
      // PARTIE H — le pharmacien ne peut modifier QUE le statut et les
      // métadonnées de traitement, jamais le contenu médical
      // (patient_id, doctor_uid, diagnosis, medicines, establishmentId,
      // pharmacyUid, date) : sans ça, un pharmacien pouvait réécrire
      // n'importe quel champ, y compris falsifier l'auteur ou le
      // diagnostic d'une ordonnance déjà envoyée.
      allow update: if isAdmin() ||
        (pharmacyCanReadPrescription(resource.data) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'updatedAt', 'updatedByUid', 'updatedByRole', 'cancelReason'])) ||
        (doctorCanRead(resource.data) &&
         hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') || ownsPatientData(request.resource.data)) &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data) || ownsPatientData(resource.data);
    }

    match /notifications/{notificationId} {
      allow read, update: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.to_id == request.auth.uid ||
            resource.data.recipientUid == request.auth.uid ||
            resource.data.userUid == request.auth.uid
          )
        );
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /registration_requests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() ||
        (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /establishments/{establishmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    /* PARTIE G/E — trace/audit des documents médicaux par établissement.
       Lecture : admin, auteur, ou membre actif du même établissement
       (PARTIE E — remplace l'ancien signedIn() trop large, qui donnait
       accès à tout utilisateur connecté sans lien avec l'hôpital).
       L'écriture reste réservée à l'auteur ou à l'admin, jamais
       modifiable après coup. */
    match /establishment_documents/{documentId} {
      allow read: if isAdmin() ||
        (signedIn() && resource.data.doctorUid == request.auth.uid) ||
        belongsToSameEstablishment(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.doctorUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /affiliation_requests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() ||
        (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* PARTIE B/C — mc_accounts reste en lecture publique (nécessaire
       au lookup pré-authentification par numéro pro/patient : fermer
       ça casserait la connexion de tout le personnel — voir
       docs/FIREBASE_KEY_SECURITY.md). Le vrai correctif porte sur ce
       qui PEUT y être écrit : hasNoSecretFields interdit désormais
       tout champ password/pin/passwordHash, y compris ici (absent
       jusqu'ici) — le PIN patient est géré exclusivement par Firebase
       Authentication (js/auth.js), jamais stocké en clair ni haché
       localement dans ce document public. */
    // Correctif (revue de sécurité) : rien n'empêchait de poser un
    // authUid arbitraire (potentiellement celui d'un tiers) sur un
    // nouveau document — un attaquant connaissant un numéro de fiche
    // patient pouvait ainsi préempter mc_accounts/PAT_{id} avec SON
    // PROPRE authUid avant que le vrai patient ne crée son compte, et
    // satisfaire ensuite isConcernedPatient() à sa place. On exige
    // désormais que authUid, quand il est posé, corresponde à
    // l'utilisateur réellement connecté qui écrit — pas de contrainte
    // signedIn() globale ici : l'inscription professionnelle en mode
    // dégradé (Firebase Auth indisponible, cf. js/auth.js
    // _createFirebaseUser) écrit encore mc_accounts SANS authUid, et ce
    // repli existant ne doit pas casser.
    // Correctif (chantier "code d'accès hôpital") : la limite ci-dessus
    // (préemption d'une fiche patient avec sa PROPRE identité Firebase)
    // est désormais fermée pour les comptes patient par
    // patientFirstAccessOk() — la création exige le code communiqué
    // hors ligne par l'hôpital à la création de la fiche (voir
    // js/db.js addPatient / js/hospital.js showFirstAccessCodeModal),
    // pas seulement la connaissance du numéro MC-xxx.
    match /mc_accounts/{docId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/mc_accounts/$(docId)) &&
        (request.resource.data.get('authUid', null) == null ||
         (signedIn() && request.resource.data.get('authUid', null) == request.auth.uid)) &&
        patientFirstAccessOk(request.resource.data.get('patient_id', null), request.resource.data.get('firstAccessCode', null)) &&
        hasNoSecretFields(request.resource.data);
      // Correctif (chantier "durcissement sans Cloud Functions") :
      // contrairement à users/doctors/nurses/pharmacies
      // (safeSelfUserUpdate/status figé sauf isAdmin()), cette règle
      // n'imposait PAS l'immuabilité du statut — un professionnel dont
      // les écritures secondaires (users/{uid}, collection de rôle)
      // échouent (hors-ligne, rôle lab/reception sans collection
      // dédiée) pouvait, dans ce cas précis, forger lui-même
      // mc_accounts.status = 'approved'. Même contrainte que les
      // autres collections de compte : status figé sauf isAdmin().
      allow update: if hasNoSecretFields(request.resource.data) && (
        isAdmin() ||
        ((signedIn() && request.auth.uid == docId) &&
         request.resource.data.get('status', null) == resource.data.get('status', null)) ||
        ((signedIn() && resource.data.get('authUid', null) == request.auth.uid) &&
         request.resource.data.get('status', null) == resource.data.get('status', null))
      );
      // Correctif (chantier "suppression de compte") : le propriétaire
      // peut supprimer son propre document mc_accounts — cas pro
      // (docId == uid) et cas patient (docId == 'PAT_{id}', identifié
      // via authUid, comme pour update ci-dessus).
      allow delete: if isAdmin() ||
        (signedIn() && request.auth.uid == docId) ||
        (signedIn() && resource.data.get('authUid', null) == request.auth.uid);
    }

    match /mc_verified_doctors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_verified_pharms/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_verified_nurses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_consultations/{docId} {
      // PARTIE E : l'ancien "currentRoleIs('doctor') || currentRoleIs('nurse')"
      // sans filtre établissement laissait n'importe quel médecin/
      // infirmier lire TOUTE la collection, y compris d'autres hôpitaux
      // — remplacé par belongsToSameEstablishment (aucun consentement
      // requis pour l'établissement créateur, clarification client).
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      // Créer/valider une consultation = acte médical : médecin
      // uniquement (l'infirmier peut lire, pas créer). Verrouillage
      // serveur du contrôle de capacité côté client.
      allow write: if canDecideMedical();
    }

    match /mc_vaccinations/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
    }

    match /mc_lab_results/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
    }

    match /mc_medicines/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin() || currentRoleIs('pharmacist');
    }

    match /mc_sales/{docId} {
      allow read: if isAdmin() || currentRoleIs('pharmacist');
      allow write: if isAdmin() || currentRoleIs('pharmacist');
    }

    /* PARTIE D — un utilisateur connecté quelconque pouvait auparavant
       créer/lire/modifier N'IMPORTE QUEL consentement (allow read/write:
       if signedIn()). Resserré : seul le médecin demandeur peut créer
       SA demande (statut initial 'pending' imposé) ; lecture réservée
       au patient concerné, au médecin demandeur, ou à l'admin ; seul
       le patient concerné peut approuver/refuser/révoquer (champs
       limités à status/decided_at/expires_at/updated_at) ; le médecin
       demandeur peut uniquement révoquer sa propre demande, jamais
       l'approuver lui-même. RAPPEL (clarification client) : ce
       mécanisme ne sert JAMAIS à l'accès de l'établissement créateur
       de la fiche (voir belongsToSameEstablishment) — uniquement aux
       accès externes explicitement demandés par un médecin. */
    match /mc_consents/{docId} {
      allow read: if isAdmin() ||
        isConcernedPatient(resource.data.patient_id) ||
        (signedIn() && resource.data.doctor_id == request.auth.uid);
      allow create: if isAdmin() ||
        (signedIn() &&
         request.resource.data.doctor_id == request.auth.uid &&
         request.resource.data.status == 'pending' &&
         request.resource.data.patient_id is string &&
         request.resource.data.patient_id != '');
      allow update: if isAdmin() ||
        (isConcernedPatient(resource.data.patient_id) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'decided_at', 'expires_at', 'updated_at'])) ||
        (signedIn() && resource.data.doctor_id == request.auth.uid &&
         request.resource.data.status == 'revoked' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'decided_at', 'updated_at']));
      allow delete: if isAdmin();
    }

    match /mc_patients/{docId} {
      // PARTIE E : remplace l'ancien "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" (accès à TOUTE la collection, y compris
      // d'autres établissements) par belongsToSameEstablishment — le
      // cas central de la clarification client : le médecin/infirmier
      // membre de l'établissement CRÉATEUR de la fiche y accède SANS
      // consentement (mc_consents ne sert qu'aux accès externes).
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      allow write: if isAdmin();
    }

    match /mc_prescriptions/{docId} {
      // PARTIE E : remplace l'ancien "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" (accès à TOUTE la collection, tous
      // établissements confondus) par belongsToSameEstablishment —
      // sans consentement pour l'établissement créateur (clarification
      // client), plus l'auteur direct et le pharmacien ciblé.
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data) ||
        pharmacyCanReadPrescription(resource.data);
      allow create: if isAdmin() || currentRoleIs('doctor');
      // PARTIE H — même restriction de champs que /prescriptions : le
      // pharmacien ne modifie jamais le contenu médical, uniquement le
      // statut et ses métadonnées de traitement.
      allow update: if isAdmin()
        || doctorCanRead(resource.data)
        || (pharmacyCanReadPrescription(resource.data) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt', 'updatedByUid', 'updatedByRole', 'cancelReason']));
      allow delete: if isAdmin();
    }

    match /mc_appointments/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin();
    }

    match /mc_messages/{docId} {
      allow read, update: if isAdmin() || (signedIn() && resource.data.to_id == request.auth.uid);
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /mc_hospitals/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mc_affiliations/{docId} {
      allow read: if isAdmin() || (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow write: if isAdmin();
    }

    /* ══════════════════════════════════════════════════
       CONTRAT D'ÉCHANGE MOBILE ↔ DESKTOP
       Chaque document porte hospitalId + createdByUid. L'écriture
       exige : membre signé, et abonnement actif/grace_period —
       vérifié côté serveur (hospitalCanWrite), pas seulement en JS.
       L'admin garde un accès de secours pour la maintenance.
    ══════════════════════════════════════════════════ */
    match /subscriptions/{hospitalId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /consultations/{docId} {
      allow read: if isAdmin() || canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /labRequests/{docId} {
      // PARTIE E : remplace le "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" non filtré par belongsToSameEstablishment.
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /labResults/{docId} {
      allow read: if isAdmin() || canReadMedicalData(resource.data);
      // Saisir un résultat = capacité labo/médecin ET gating device.
      allow create: if isAdmin() ||
        (canEnterLabResult() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (canEnterLabResult() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /messages/{docId} {
      allow read: if isAdmin() ||
        (signedIn() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid));
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && resource.data.toUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readStatus','readAt']));
      allow delete: if isAdmin();
    }

    /* PARTIE E — un membre ne peut écrire QUE son propre document
       ({hospitalId}_{son uid}, avec uid == son propre uid) : aucune
       élévation de privilège possible même en auto-guérison côté
       client (ensureHospitalMembership). L'admin garde la main pour
       l'approbation/le retrait effectués depuis le tableau de bord
       (l'acteur est alors l'admin, pas le membre lui-même).

       Correctif (revue de sécurité) : la seule contrainte docId/uid
       ci-dessus ne vérifiait PAS que l'affiliation était réellement
       approuvée — n'importe quel compte connecté qui connaît un
       hospitalId pouvait s'auto-écrire un statut "active" et obtenir
       ainsi tout l'accès belongsToSameEstablishment de cet
       établissement. hasApprovedAffiliation() exige la préexistence
       d'un affiliation_requests/AFF_{uid}_{hospitalId} au statut
       "approved" — document que seul un admin peut faire passer à ce
       statut (voir la règle affiliation_requests). L'auto-écriture
       reste donc un simple MIROIR d'un fait déjà approuvé côté
       serveur, jamais une élévation indépendante. */
    function hasApprovedAffiliation(hospitalId) {
      return hospitalId != null &&
        exists(/databases/$(database)/documents/affiliation_requests/$('AFF_' + request.auth.uid + '_' + hospitalId)) &&
        get(/databases/$(database)/documents/affiliation_requests/$('AFF_' + request.auth.uid + '_' + hospitalId)).data.status == 'approved';
    }
    match /hospitalMembers/{docId} {
      allow read: if isAdmin() || signedIn();
      allow create, update: if isAdmin() ||
        (signedIn() &&
         docId == (resolveHospitalId(request.resource.data) + '_' + request.auth.uid) &&
         request.resource.data.uid == request.auth.uid &&
         request.resource.data.status == 'active' &&
         hasApprovedAffiliation(resolveHospitalId(request.resource.data)));
      // Correctif (chantier "suppression de compte") : un membre peut
      // supprimer son propre document d'affiliation (utilisé lors de
      // la suppression de compte pour nettoyer hospitalMembers).
      allow delete: if isAdmin() || (signedIn() && resource.data.get('uid', null) == request.auth.uid);
    }

    /* ── Bundle desktop hôpital (adapté) — beds/admissions/aiQueries ── */
    match /beds/{docId} {
      allow read: if isAdmin() || signedIn();
      allow create, update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /admissions/{docId} {
      // PARTIE E : remplace le "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" non filtré (accès inter-établissements)
      // par belongsToSameEstablishment.
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      allow create, update: if isAdmin() ||
        (canManageCare() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /receptionVisits/{docId} {
      // PARTIE E : même correctif que admissions.
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /emergencyCases/{docId} {
      // PARTIE E : même correctif que admissions.
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /maternityCases/{docId} {
      // PARTIE E : même correctif que admissions.
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /aiQueries/{docId} {
      // Historique des requêtes IA médicale : lecture réservée à
      // l'auteur et à l'admin (peut contenir du contexte clinique).
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{docId} {
      // Journal d'audit : création libre pour tout utilisateur
      // signé (traçabilité, y compris des tentatives bloquées par
      // abonnement), jamais modifiable après coup. Lecture : admin,
      // et personnel clinique vérifié — même précédent que
      // admissions/receptionVisits ci-dessus (rôle vérifié au niveau
      // règle, portée établissement appliquée côté requête client
      // via listByHospital). Nécessaire pour l'onglet "Historique des
      // accès" du dossier médical (MedicalRecordDesktop), réservé aux
      // rôles cliniques dans l'UI.
      // PARTIE E : remplace le "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" (accès à tout le journal, tous
      // établissements) par belongsToSameEstablishment.
      allow read: if isAdmin() || belongsToSameEstablishment(resource.data);
      // Correctif (chantier "durcissement sans Cloud Functions") :
      // "if signedIn()" seul ne contraignait AUCUN champ — n'importe
      // quel utilisateur connecté pouvait créer une entrée d'audit au
      // nom d'un tiers (userId arbitraire). Un vrai journal
      // infalsifiable ET non-omissible nécessite un trigger serveur
      // (Cloud Function), donc le plan Blaze — hors de portée sur
      // Spark. Mitigation atteignable ici : quand le champ userId est
      // posé, il doit correspondre à l'auteur réel de la requête (ferme
      // la forge d'identité) ; absent, la création reste tolérée pour
      // ne pas casser les appelants existants qui ne le posent pas
      // encore. Ne ferme PAS l'omission volontaire d'un log (impossible
      // à forcer sans code serveur) — limite à garder honnête dans le
      // rapport.
      allow create: if signedIn() &&
        (request.resource.data.get('userId', null) == null ||
         request.resource.data.get('userId', null) == request.auth.uid);
      allow update, delete: if false;
    }

    /* ── Version manager : maintenance / version minimale ──
       Lecture publique (même non authentifié : le bandeau de
       maintenance doit rester visible avant connexion), écriture
       réservée à l'administrateur plateforme. */
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ── Transfert d'urgence inter-hôpitaux ─────────────
       Point 12 de la commande : l'hôpital destinataire n'a JAMAIS
       le droit de modifier les données médicales d'un autre hôpital.
       Seul l'hôpital source (créateur) peut modifier le statut du
       transfert ; le destinataire ne peut que LIRE, et faire
       progresser le statut via les actions dédiées (accepter,
       marquer en transit/arrivé) sans toucher au contenu médical
       (emergencyPacket reste figé après création — non modifiable
       par update, seul le statut/timestamps changent). */
    match /emergencyTransfers/{transferId} {
      // PARTIE I : remplace le "signedIn()" trop large (tout utilisateur
      // connecté, y compris hors du transfert) par une vérification
      // réelle d'appartenance à l'hôpital source OU destinataire (ou
      // patient concerné), en plus de l'admin.
      allow read: if isAdmin() ||
        isHospitalMember(resource.data.fromHospitalId) ||
        isHospitalMember(resource.data.toHospitalId) ||
        isConcernedPatient(resource.data.patientId);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // Mise à jour de statut : l'hôpital source ou le destinataire
      // peuvent faire progresser le transfert, mais le paquet
      // médical (emergencyPacket) et l'origine ne peuvent jamais
      // être réécrits après création.
      allow update: if isAdmin() ||
        (signedIn() &&
         request.resource.data.emergencyPacket == resource.data.emergencyPacket &&
         request.resource.data.fromHospitalId == resource.data.fromHospitalId &&
         request.resource.data.patientId == resource.data.patientId);
      allow delete: if isAdmin();
    }

    match /medical_record_shares/{shareId} {
      // PARTIE I : lecture réellement réservée à l'hôpital source,
      // l'hôpital destinataire, le patient concerné, ou l'admin — le
      // "signedIn()" précédent laissait n'importe quel utilisateur
      // connecté lire n'importe quel partage, tiers inclus.
      allow read: if isAdmin() ||
        isHospitalMember(resource.data.fromHospitalId) ||
        isHospitalMember(resource.data.toHospitalId) ||
        isConcernedPatient(resource.data.patientId);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // Seuls le statut/timestamps de révocation peuvent changer —
      // les sections partagées (allowedSections) et l'origine du
      // partage sont figées après création.
      // Correctif (chantier "durcissement sans Cloud Functions") :
      // "signedIn()" seul laissait N'IMPORTE QUEL utilisateur connecté
      // (un tiers sans aucun lien avec ce partage) faire progresser son
      // statut — restreint désormais exactement aux mêmes parties
      // légitimes que la règle "read" ci-dessus (l'hôpital source, le
      // destinataire qui approuve via js/hospital.js
      // approveIncomingShare, ou le patient concerné), jamais un tiers
      // quelconque.
      allow update: if isAdmin() ||
        ((isHospitalMember(resource.data.fromHospitalId) ||
          isHospitalMember(resource.data.toHospitalId) ||
          isConcernedPatient(resource.data.patientId)) &&
         request.resource.data.allowedSections == resource.data.allowedSections &&
         request.resource.data.fromHospitalId == resource.data.fromHospitalId &&
         request.resource.data.patientId == resource.data.patientId);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
