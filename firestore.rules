rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasCurrentUserDoc() {
      return signedIn() && exists(currentUserDoc());
    }

    // Correctif (chantier "durcissement sans Cloud Functions", plan
    // Firebase Spark/gratuit) : suspendre un compte (users/{uid}.status)
    // ne révoquait jusqu'ici AUCUNE session Firebase Auth déjà active —
    // le SDK rafraîchit son jeton silencieusement, et les fonctions de
    // capacité ci-dessous ne vérifiaient que le RÔLE, jamais le statut
    // du compte agissant. Un professionnel suspendu gardait donc tous
    // ses droits Firestore jusqu'à expiration naturelle de sa session.
    // Une vraie révocation de session (admin.auth().revokeRefreshTokens)
    // nécessite l'Admin SDK, donc une Cloud Function, donc le plan
    // Blaze — hors de portée tant que le projet reste sur Spark.
    // accountStatusOk() referme l'accès aux DONNÉES (Firestore, le
    // seul point sensible ici) en temps quasi réel : dès que le champ
    // status bascule, la toute prochaine requête est refusée, sans
    // attendre l'expiration du token. Ce n'est pas l'équivalent d'une
    // vraie révocation de session Auth, mais ça ferme concrètement
    // l'accès aux données — nuance à ne jamais présenter comme
    // équivalente dans la documentation. Défaut permissif si le champ
    // status est absent (comptes existants non encore dotés d'un
    // statut individuel — rétro-compatibilité, même logique que
    // subscriptionStatus()/hospitalSubscriptionOk() plus bas).
    function accountStatusOk() {
      return !hasCurrentUserDoc() ||
        get(currentUserDoc()).data.get('status', 'approved') in ['approved', 'active'];
    }

    // NOTE — bug corrigé pendant ce chantier (découvert en écrivant les
    // tests d'émulateur, tests/firestore-rules/) : un accès direct en
    // notation pointée à un custom claim jamais explicitement posé
    // (request.auth.token.role / .admin) lève une erreur d'évaluation
    // ("Property X is undefined") plutôt que de retourner null, quand
    // le token ne porte STRICTEMENT AUCUNE valeur pour cette clé — ce
    // qui n'arrive jamais avec un vrai jeton Firebase Auth de
    // production (toujours "complet"), mais arrive bel et bien avec un
    // compte qui n'a reçu aucun custom claim (le cas courant : la
    // plupart des comptes n'ont pas de claim 'role', le rôle vit dans
    // users/{uid}). Le déni en résultait presque toujours (Firestore
    // refuse par défaut sur exception), mais silencieusement et de
    // façon fragile. .get(key, défaut) sur le token (une Map) est la
    // façon robuste de lire un champ optionnel sans jamais lever.
    function currentRoleIs(role) {
      return signedIn() && accountStatusOk() && (
        request.auth.token.get('role', null) == role ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == role)
      );
    }

    function isAdmin() {
      return signedIn() && accountStatusOk() && (
        request.auth.token.get('admin', false) == true ||
        request.auth.token.get('role', null) == 'admin' ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == 'admin')
      );
    }

    /* ── CAPACITÉS PAR RÔLE (miroir serveur de HospitalCapabilities) ──
       Le rôle est lu depuis users/{uid} (currentRoleIs) ou le token :
       il est VÉRIFIÉ, non déclaré par le client. Ces helpers permettent
       aux règles de refuser elles-mêmes une action que le rôle ne
       permet pas — même si le client contourne le JavaScript.
       Note : admin_hospital et lab n'ont pas de rôle mobile ; ils
       apparaissent ici pour le desktop. La source reste users/{uid}. */
    function hasRole(role) {
      return signedIn() && accountStatusOk() && (
        request.auth.token.get('role', null) == role ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == role)
      );
    }
    // 'hospital' = compte propriétaire d'un établissement (créé à
    // l'inscription desktop). Il n'écrit PAS de données médicales
    // lui-même : chaque agent s'authentifie avec SON compte personnel,
    // et c'est SON rôle réel (doctor/nurse/lab/reception) que les
    // capacités ci-dessous vérifient. Le serveur distingue donc les
    // agents entre eux.
    // Décider/valider un acte médical : médecin (ou admin plateforme/hôpital)
    function canDecideMedical() {
      return isAdmin() || hasRole('doctor') || hasRole('admin_hospital');
    }
    // Prescrire : strictement médecin
    function canPrescribe() {
      return isAdmin() || hasRole('doctor');
    }
    // Décider un transfert médical : médecin (ou admin hôpital)
    function canDecideTransfer() {
      return isAdmin() || hasRole('doctor') || hasRole('admin_hospital');
    }
    // Admettre / sortir / gérer lits : personnel de soins
    function canManageCare() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') || hasRole('admin_hospital');
    }
    // Saisir un résultat de labo : laborantin (ou médecin/admin)
    function canEnterLabResult() {
      return isAdmin() || hasRole('lab') || hasRole('doctor') || hasRole('admin_hospital');
    }
    // Demander une analyse : médecin, infirmier, admin hôpital (jamais
    // le laborantin lui-même — voir chantier "modales laboratoire").
    function canRequestLab() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') || hasRole('admin_hospital');
    }
    // Enregistrer une arrivée / créer patient à l'accueil : réception + soignants
    function canRegisterPatient() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') ||
             hasRole('reception') || hasRole('admin_hospital');
    }

    /* ── Chantier "reception/affiliation sans régression" — section 4 ──
       Bug confirmé : la matrice client (js/hospital-capabilities.js)
       autorise la réception à créer un patient, mais AUCUNE clause
       create de mc_patients/patients/medical_records ne couvrait ce
       rôle avant ce correctif (seuls isAdmin()/doctor/nurse pouvaient
       écrire) — la fiche restait provisoire en cache local, jamais
       confirmée. La réception ne doit créer QUE des champs
       d'identité/administratifs — jamais de contenu clinique
       (diagnostic, allergies, antécédents, traitement, consultation,
       ordonnance, résultat labo, historique clinique, notes médecin) :
       hasOnly() sur le document entier fait échouer toute écriture
       portant une clé hors de cette liste. Inclut created_by_role/
       created_by_name/establishmentName, déjà posés par le helper
       partagé currentEstablishmentFields() (js/hospital.js), utilisé
       tel quel par la réception — ne pas les omettre casserait sa
       création dès ce correctif. */
    function receptionPatientCreateOk(data) {
      return hasRole('reception') &&
        data.keys().hasOnly([
          'id', 'firstname', 'lastname', 'dob', 'birthdate', 'gender', 'phone',
          'address', 'country_code', 'firstAccessCode',
          'establishmentId', 'hospital_id', 'establishmentName',
          'created_by', 'created_by_role', 'created_by_name',
          'created_at', 'updated_at', 'emergencyIntake', 'sourceDevice'
        ]);
    }

    /* ── Transitions de statut labRequests (chantier "modales
       laboratoire") ── Empêche qu'un client modifié fasse revenir une
       demande completed à requested, ou saute directement de requested
       à completed sans passer par un laborantin. oldStatus == newStatus
       est toujours autorisé (une mise à jour peut ne toucher aucun
       champ de statut). */
    function labStatusTransitionOk(oldStatus, newStatus) {
      return oldStatus == newStatus ||
        (oldStatus == 'requested' && (newStatus == 'sample_pending' || newStatus == 'in_progress')) ||
        (oldStatus == 'sample_pending' && newStatus == 'in_progress') ||
        (oldStatus == 'in_progress' && newStatus == 'completed');
    }
    // Champs modifiables sur labRequests après création — tout le
    // reste (patientMc, patientName, establishmentId, hospitalId,
    // requestedByUid, requestedByRole, type, createdAt...) est
    // immuable une fois la demande créée.
    function labRequestUpdateKeysOk(before, after) {
      return after.diff(before).affectedKeys().hasOnly([
        'status', 'sampleCollectedAt', 'startedAt', 'assignedLabUid', 'assignedLabName',
        'value', 'unit', 'comment', 'completedAt', 'completedByUid', 'completedByName',
        'completedByRole', 'updatedAt'
      ]);
    }

    /* ── Abonnement établissement (contrat mobile ↔ desktop) ──
       Aucun document subscriptions/{hospitalId} => traité comme
       "active" par défaut (rétro-compatibilité : ne bloque pas les
       établissements existants tant que l'abonnement n'a pas été
       explicitement configuré). */
    function subscriptionDoc(hospitalId) {
      return /databases/$(database)/documents/subscriptions/$(hospitalId);
    }
    function subscriptionStatus(hospitalId) {
      return hospitalId != null && exists(subscriptionDoc(hospitalId))
        ? get(subscriptionDoc(hospitalId)).data.status
        : 'active';
    }
    function hospitalSubscriptionOk(hospitalId) {
      return subscriptionStatus(hospitalId) in ['active', 'grace_period'];
    }
    // Utilisée telle quelle uniquement pour /patients : la création
    // de patient reste bloquée par abonnement expiré/suspendu quelle
    // que soit la plateforme (desktop ET mobile/PWA — confirmé
    // explicitement : c'est la seule action que le mobile bloque
    // aussi).
    function hospitalCanWrite(hospitalId) {
      return hospitalSubscriptionOk(hospitalId);
    }
    // Intake d'URGENCE (js/hospital-emergency.js) : la création d'un
    // nouveau patient aux urgences n'est JAMAIS coupée pour un
    // abonnement expiré — le soin d'urgence prime sur la facturation
    // (même principe que emergency-transfer). Le marqueur emergencyIntake
    // est posé par le flux urgence ; le patient le porte de façon
    // permanente (traçable).
    // ⚠️ LIMITE CONNUE — emergencyIntake est DÉCLARÉ par le client :
    // comme sourceDevice, un client desktop malveillant pourrait le poser
    // pour contourner le blocage d'abonnement à la création de patient.
    // Fermer réellement cette faille exige un custom claim serveur (Cloud
    // Function). Accepté comme limite connue, cohérent avec le reste du
    // durcissement sans backend. NE PAS présenter ce contrôle comme fort.
    function isEmergencyIntake(data) {
      return data.get('emergencyIntake', false) == true;
    }
    // Utilisée pour consultations/prescriptions/labRequests/
    // labResults/appointments/messages/hospitalMembers : le mobile/PWA
    // reste autorisé à écrire même hôpital expiré (le soin courant ne
    // doit jamais être coupé pour une facture desktop impayée) ; seul
    // le desktop est réellement bloqué. Le signal sourceDevice vient
    // du document envoyé par le client (voir note de risque résiduel
    // dans le rapport final : un client malveillant pourrait usurper
    // ce champ — accepté comme limite connue, pas de nouveau système
    // d'auth introduit pour ce chantier).
    // ⚠️ LIMITE DE SÉCURITÉ CONNUE — sourceDevice est DÉCLARÉ par le
    // client : un client desktop peut envoyer sourceDevice:'mobile'
    // pour contourner le blocage d'abonnement. Fermer réellement cette
    // faille exige un custom claim posé côté serveur (Cloud Function),
    // que les règles liraient via request.auth.token.deviceType au lieu
    // du champ du document. Tant que ce backend n'existe pas, le gating
    // desktop reste dissuasif mais non infalsifiable. NE PAS présenter
    // ce contrôle comme une sécurité forte.
    // PORTÉE RÉDUITE (correctif abonnement) : ce risque ne concerne
    // plus que les collections cliniques PARTAGÉES avec le mobile
    // (consultations, ordonnances, rendez-vous, messages). Les
    // collections des workflows desktop-only sont désormais gatées
    // inconditionnellement par l'abonnement, sans lire sourceDevice —
    // voir desktopWorkflowCanWrite ci-dessous.
    // Migration future : remplacer `deviceValue` par
    // `request.auth.token.deviceType` ici, sans toucher aux appelants.
    function hospitalCanWriteFromDevice(hospitalId, deviceValue) {
      return hospitalSubscriptionOk(hospitalId) || deviceValue != 'desktop';
    }

    /* ── Chantier "reception/affiliation sans régression" — section 12 ──
       Bug confirmé : mc_messages.create ne vérifiait JAMAIS l'identité
       de l'expéditeur — n'importe quel compte connecté pouvait poser
       fromUid/from_id/senderUid/createdByUid à l'identité de N'IMPORTE
       QUI (usurpation), y compris pour se faire passer pour un médecin
       ou un administrateur dans une notification. Network.notify()
       (js/network.js) pose toujours `fromUid: from?.uid` (le SEUL champ
       réellement utilisé en écriture aujourd'hui) — mais on accepte ici
       aussi les variantes historiques du même concept (from_id,
       senderUid, createdByUid) par prudence/rétro-compatibilité, sans
       jamais les exiger toutes à la fois : seul un champ RÉELLEMENT
       présent doit correspondre à request.auth.uid, et si PLUSIEURS de
       ces champs sont présents ils doivent tous pointer vers la même
       identité (jamais deux identités contradictoires dans un même
       document). Un document n'en posant AUCUN passe (comme
       aujourd'hui : notifications système historiques sans expéditeur
       humain identifié — ne durcit pas ce cas, hors scope). */
    // Correctif P0 (audit "workflows mobile/desktop", section 17) :
    // cette fonction vérifiait déjà que TOUT champ d'identité PRÉSENT
    // correspondait à l'auteur réel (anti-usurpation), mais n'exigeait
    // AUCUN de ces champs — un message sans fromUid/from_id/senderUid/
    // createdByUid passait cette vérification par défaut. js/network.js
    // notify() (seul point d'écriture réel de mc_messages/messages) pose
    // TOUJOURS fromUid (au pire null si Auth.getUser() n'est pas encore
    // peuplé, ce qui n'arrive pas en usage normal signedIn()) : exiger
    // au moins un identifiant réel ferme la possibilité d'un message
    // sans aucune identité d'expéditeur, sans affecter l'usage réel.
    function messageSenderIdentityOk(data) {
      return (
        data.get('fromUid', null) != null ||
        data.get('from_id', null) != null ||
        data.get('senderUid', null) != null ||
        data.get('createdByUid', null) != null
      ) &&
        (data.get('fromUid', null) == null || data.get('fromUid', null) == request.auth.uid) &&
        (data.get('from_id', null) == null || data.get('from_id', null) == request.auth.uid) &&
        (data.get('senderUid', null) == null || data.get('senderUid', null) == request.auth.uid) &&
        (data.get('createdByUid', null) == null || data.get('createdByUid', null) == request.auth.uid);
    }

    /* ── LECTURE mobile du dossier médical par le personnel clinique ──
       Demande client : un contenu (consultation/ordonnance/résultat de
       labo) créé côté DESKTOP hôpital ne doit être visible au médecin/
       infirmier(ère) que si l'abonnement de l'établissement est actif —
       jamais pour le patient (toujours visible, principe inchangé), et
       jamais pour le contenu créé côté MOBILE (toujours visible aux
       professionnels, jamais coupé — principe hospitalCanWriteFromDevice
       existant, inchangé ici).
       ⚠️ LIMITE CONNUE (même famille que hospitalCanWriteFromDevice) :
       les règles ne peuvent pas distinguer une lecture depuis l'app
       mobile d'une lecture depuis le desktop pour un même compte
       Firebase — seul sourceDevice, DÉCLARÉ sur le document au moment
       de sa création, est disponible sans backend. Un médecin/
       infirmier(ère) qui relit depuis le desktop DE CE MÊME hôpital un
       contenu que ce dernier a lui-même créé sera donc logiquement
       soumis à la même règle tant que l'abonnement est inactif — accepté
       comme limite technique, cohérent avec le reste du projet (aucune
       Cloud Function). NE PAS présenter comme une détection fiable du
       device courant.
    */
    function clinicalStaffCanReadDesktopContent(data) {
      return data.get('sourceDevice', null) != 'desktop' ||
        hospitalSubscriptionOk(resolveHospitalId(data));
    }
    function subscriptionReadGateOk(data) {
      return !(currentRoleIs('doctor') || currentRoleIs('nurse')) ||
        clinicalStaffCanReadDesktopContent(data);
    }
    // Collections des WORKFLOWS DESKTOP (beds / admissions /
    // receptionVisits / labRequests / labResults / emergencyCases /
    // maternityCases / aiQueries) : elles ne sont JAMAIS écrites par la
    // version mobile (seuls les modules js/hospital-*.js et
    // js/medical-ai.js du portail desktop y écrivent) — le repli
    // « mobile jamais coupé » n'a donc aucun sens ici, et AUCUNE
    // dépendance au champ sourceDevice déclaré par le client n'est
    // nécessaire. L'abonnement est exigé INCONDITIONNELLEMENT :
    // contrairement à hospitalCanWriteFromDevice, ce contrôle est
    // infalsifiable côté client. Il ferme, pour tout le cœur du produit
    // desktop payant, le contournement documenté ci-dessus (spoof de
    // sourceDevice). Le risque résiduel ne concerne plus que les
    // collections cliniques PARTAGÉES avec le mobile (consultations,
    // ordonnances, rendez-vous, messages), où le champ déclaré reste le
    // seul signal possible sans backend.
    function desktopWorkflowCanWrite(hospitalId) {
      return hospitalSubscriptionOk(hospitalId);
    }
    // Le code applicatif écrit establishmentId (parfois hospital_id
    // en repli historique) — jamais un champ "hospitalId" littéral.
    // Ce helper évite de répéter ce repli dans chaque règle.
    // NOTE — bug réel corrigé pendant ce chantier (découvert en testant
    // hospitalMembers avec l'émulateur) : accès direct en notation
    // pointée à un champ que le document ne porte PAS du tout (ex :
    // hospitalMembers écrit hospitalId mais pas establishmentId) lève
    // une erreur d'évaluation ("Property X is undefined") au lieu de
    // retourner null — même famille que le bug déjà corrigé sur
    // request.auth.token. .get(clé, défaut) sur une map lit un champ
    // optionnel sans jamais lever.
    function resolveHospitalId(data) {
      return data.get('establishmentId', null) != null ? data.get('establishmentId', null)
        : (data.get('hospital_id', null) != null ? data.get('hospital_id', null)
        : (data.get('hospitalId', null) != null ? data.get('hospitalId', null) : data.get('fromHospitalId', null)));
    }

    /* ── PARTIE E — isolation par établissement (serveur) ──
       hospitalMembers/{hospitalId}_{uid} est un document PLAT écrit par
       l'application (js/hospitals_registry.js) en miroir de
       establishments.staff[] — une règle Firestore ne peut pas tester
       efficacement l'appartenance à un tableau d'objets, d'où ce doc
       à clé déterministe. isHospitalMember/belongsToSameEstablishment
       s'ajoutent en OR aux vérifications existantes (auteur direct via
       doctorCanRead/nurseCanRead/ownsPatientData) — jamais en
       remplacement : un médecin auteur direct garde toujours accès même
       sans document hospitalMembers (compte créé avant ce chantier).
       IMPORTANT (clarification client) : ce mécanisme ne dépend JAMAIS
       de mc_consents — l'accès de l'établissement CRÉATEUR de la fiche
       ne requiert aucun consentement patient ; le consentement ne sert
       qu'aux accès EXTERNES (voir mc_consents plus bas). */
    function hospitalMemberDoc(hospitalId, uid) {
      return /databases/$(database)/documents/hospitalMembers/$(hospitalId + '_' + uid);
    }
    // Correctif (revue Codex sur PR "durcissement sans Cloud
    // Functions") : accountStatusOk() n'était injecté que dans
    // hasRole()/currentRoleIs()/isAdmin() — pas ici. Or isHospitalMember()
    // est le chemin d'accès de la quasi-totalité des collections
    // médicales (belongsToSameEstablishment) : un compte suspendu
    // (users/{uid}.status) dont le document hospitalMembers restait
    // "active" gardait donc tout son accès établissement, vidant la
    // protection de suspension de l'essentiel de sa substance.
    function isHospitalMember(hospitalId) {
      return signedIn() && accountStatusOk() && hospitalId != null &&
        exists(hospitalMemberDoc(hospitalId, request.auth.uid)) &&
        get(hospitalMemberDoc(hospitalId, request.auth.uid)).data.status == 'active';
    }
    function belongsToSameEstablishment(data) {
      return isHospitalMember(resolveHospitalId(data));
    }

    /* ── Chantier "reception/affiliation sans régression" — section 9/10 ──
       Bug confirmé : belongsToSameEstablishment() seule (membre actif,
       n'importe quel rôle) était utilisée comme clause de lecture sur
       mc_consultations/mc_prescriptions/mc_lab_results/labRequests/
       labResults — donnant à la réception ET au laborantin un accès en
       lecture au contenu clinique complet (consultations, ordonnances)
       auquel leur rôle ne donne aucune capacité côté client
       (js/hospital-capabilities.js). isClinicalHospitalMember() réserve
       ces lectures au personnel réellement clinique de l'établissement
       (doctor/nurse/admin_hospital) — jamais lab, jamais reception.
       Ajout ADDITIF : remplace SEULEMENT le branchement
       belongsToSameEstablishment() sur ces 5 collections précises ;
       belongsToSameEstablishment() elle-même reste inchangée partout
       ailleurs (beds/admissions/receptionVisits/mc_admissions...), où
       reception a légitimement besoin d'un accès établissement complet. */
    function isClinicalHospitalMember(data) {
      return (hasRole('doctor') || hasRole('nurse') || hasRole('admin_hospital')) &&
        belongsToSameEstablishment(data);
    }
    // Le laborantin lit les données de LABO (demandes/résultats) de son
    // établissement — jamais les consultations/ordonnances (voir
    // isClinicalHospitalMember ci-dessus, qui ne l'inclut jamais).
    function labCanReadLabData(data) {
      return hasRole('lab') && belongsToSameEstablishment(data);
    }
    // Identité administrative seulement (numéro MC, nom, naissance...) —
    // Firestore ne peut pas restreindre des CHAMPS au sein d'un même
    // document lu : tant qu'aucune vue dédiée (ex. patient_directory)
    // n'existe, ce helper documente l'intention sans pouvoir la faire
    // respecter seul ; mc_patients reste donc, pour l'instant, un accès
    // établissement complet pour reception/lab (limite connue, cf.
    // rapport final — la recherche patient de réception/labo en dépend
    // directement, voir js/hospital-reception.js/js/hospital-lab.js).
    function receptionCanReadPatientIdentity(data) {
      return hasRole('reception') && belongsToSameEstablishment(data);
    }
    function labCanReadPatientIdentity(data) {
      return hasRole('lab') && belongsToSameEstablishment(data);
    }

    /* ── Correctif (audit "workflows mobile/desktop", section 18) ──────
       Bug confirmé, même famille que isClinicalHospitalMember ci-dessus :
       admissions/receptionVisits/emergencyCases/maternityCases/beds
       utilisaient belongsToSameEstablishment() SEULE en lecture — tout
       membre actif de l'établissement pouvait lire ces documents, y
       compris lab et pharmacist, dont AUCUNE capacité côté client
       (js/hospital-capabilities.js) ni aucune route de menu
       (js/hospital-permissions.js ROUTES) ne couvre ces collections.
       Coordination des soins = personnel clinique (doctor/nurse/
       admin_hospital) ET réception (qui orchestre réellement arrivées/
       pré-admissions/lits, cf. js/hospital-reception.js) — jamais lab,
       jamais pharmacist. */
    function careCoordinationCanRead(data) {
      return isClinicalHospitalMember(data) || (hasRole('reception') && belongsToSameEstablishment(data));
    }

    /* ── Chantier "reception/affiliation sans régression" — section 9 ──
       Décider d'une affiliation (approuver/refuser) : l'admin plateforme
       garde un accès global ; l'admin_hospital ne peut décider QUE pour
       SON PROPRE établissement (membre actif de l'établissement de la
       demande). Correctif d'un bug confirmé : l'interface (bouton
       "Approuver"/"Refuser" du tableau de bord desktop hôpital) affichait
       cette action à admin_hospital, mais Firestore ne l'autorisait
       jusqu'ici qu'à isAdmin() — la décision échouait toujours
       silencieusement pour admin_hospital. */
    function canManageAffiliation(data) {
      return isAdmin() ||
        (hasRole('admin_hospital') && isHospitalMember(resolveHospitalId(data)));
    }
    // Champs qu'une décision (approbation/refus) peut modifier — jamais
    // requesterUid/requesterRole/establishmentId/professionalNumber, qui
    // restent tels que déposés à la création de la demande.
    function affiliationDecisionFieldsOk(before, after) {
      return after.diff(before).affectedKeys().hasOnly([
        'status', 'updatedAt', 'decided_at', 'decidedByUid', 'decidedByRole', 'decisionReason'
      ]);
    }
    // Variante de hasApprovedAffiliation() (définie plus bas, pour
    // l'auto-écriture de SA PROPRE affiliation) qui vérifie l'affiliation
    // d'un uid ARBITRAIRE — nécessaire pour que admin_hospital puisse
    // activer hospitalMembers au nom du professionnel dont il vient
    // d'approuver la demande (l'acteur est l'admin_hospital, jamais le
    // membre lui-même — même principe déjà documenté pour isAdmin() plus
    // bas). Exige que la demande existe et soit pending OU déjà approved
    // pour CE uid et CET établissement — jamais une élévation
    // indépendante d'une demande inexistante ou refusée.
    function hasPendingOrApprovedAffiliationFor(uid, hospitalId) {
      return uid != null && hospitalId != null &&
        exists(/databases/$(database)/documents/affiliation_requests/$('AFF_' + uid + '_' + hospitalId)) &&
        get(/databases/$(database)/documents/affiliation_requests/$('AFF_' + uid + '_' + hospitalId)).data.status in ['pending', 'approved'];
    }

    function ownsUid(uid) {
      return signedIn() && uid == request.auth.uid;
    }

    function uidIn(listValue) {
      return signedIn() && listValue is list && request.auth.uid in listValue;
    }

    // NOTE — même correctif que resolveHospitalId/currentRoleIs :
    // .get(clé, défaut) plutôt que l'accès pointé direct, qui lève une
    // erreur d'évaluation quand le document ne porte pas du tout ce
    // champ (constaté avec l'émulateur sur plusieurs collections où
    // tous les documents n'ont pas tous les mêmes champs optionnels).
    function ownsPatientData(data) {
      return signedIn() && (
        data.get('uid', null) == request.auth.uid ||
        data.get('patientUid', null) == request.auth.uid ||
        data.get('patient_uid', null) == request.auth.uid ||
        data.get('ownerUid', null) == request.auth.uid ||
        // PARTIE B — patient authentifié via Firebase Auth (PIN migré,
        // voir js/auth.js _createPatientFirebaseAuth/_signInPatientFirebaseAuth).
        // Le compte garde un uid stable 'PAT_'+id (adressage mc_accounts) ;
        // patientAuthUid porte l'uid Firebase réel. Clause tolérante :
        // aucun code client n'écrit encore ce champ sur la fiche patient
        // elle-même dans cette PR (nécessiterait un mécanisme de
        // revendication dédié, hors scope) — sans effet tant qu'absent,
        // prête pour une future écriture contrôlée.
        data.get('patientAuthUid', null) == request.auth.uid
      );
    }

    function doctorCanRead(data) {
      return currentRoleIs('doctor') && (
        data.get('created_by', null) == request.auth.uid ||
        data.get('doctorUid', null) == request.auth.uid ||
        data.get('doctor_uid', null) == request.auth.uid ||
        uidIn(data.get('doctorUids', [])) ||
        uidIn(data.get('authorizedDoctorUids', []))
      );
    }

    function nurseCanRead(data) {
      return currentRoleIs('nurse') && (
        data.get('nurseUid', null) == request.auth.uid ||
        data.get('nurse_uid', null) == request.auth.uid ||
        uidIn(data.get('nurseUids', [])) ||
        uidIn(data.get('authorizedNurseUids', []))
      );
    }

    function pharmacyCanReadPrescription(data) {
      return currentRoleIs('pharmacist') && (
        data.get('pharmacyUid', null) == request.auth.uid ||
        data.get('pharmacy_uid', null) == request.auth.uid ||
        data.get('receivedByPharmacyUid', null) == request.auth.uid ||
        uidIn(data.get('pharmacyUids', []))
      );
    }

    /* ── Chantier "reception/affiliation sans régression" — section 11 ──
       Bug confirmé : mc_medicines/mc_sales n'avaient jamais de champ
       pharmacyUid, et leur règle write/read se limitait à
       "currentRoleIs('pharmacist')" — N'IMPORTE QUEL pharmacien pouvait
       lire/modifier/supprimer le stock ou les ventes de N'IMPORTE QUEL
       AUTRE pharmacien. js/db.js addMedicine()/addSale() posent
       désormais pharmacyUid à la création. Les documents créés AVANT ce
       correctif n'ont pas ce champ (aucune Cloud Function/migration de
       masse pour ce chantier) : ils restent, de façon temporaire et
       documentée, accessibles à tout pharmacien (repli rétro-compatible
       explicite) — jusqu'à ce qu'une prochaine écriture les fasse
       passer sous ce même correctif (updateMedicine() préserve
       pharmacyUid une fois posé). */
    function pharmacyOwnsOrLegacy(data) {
      return currentRoleIs('pharmacist') &&
        (data.get('pharmacyUid', null) == request.auth.uid || data.get('pharmacyUid', null) == null);
    }

    /* ── PARTIE D — consentements (mc_consents) ──
       js/access_control.js identifie un patient par patient_id (le
       numéro de fiche, ex "MC-2026-..."), pas par un uid Firebase —
       impossible à comparer directement à request.auth.uid. On résout
       donc l'uid Firebase réel du patient via mc_accounts/PAT_{patient_id}
       .authUid, posé de façon fiable à la création du compte (règle
       "create" de mc_accounts, non restreinte par auth — voir plus bas)
       une fois le PIN migré vers Firebase Authentication (PARTIE B).
       Limite assumée : un compte patient hérité pas encore migré
       (authUid absent) ne peut pas encore être vérifié ainsi côté
       règles — documenté dans le rapport final. */
    function patientAccountAuthUid(patientId) {
      return patientId != null &&
        exists(/databases/$(database)/documents/mc_accounts/$('PAT_' + patientId))
        ? get(/databases/$(database)/documents/mc_accounts/$('PAT_' + patientId)).data.authUid
        : null;
    }
    function isConcernedPatient(patientId) {
      return signedIn() && patientAccountAuthUid(patientId) == request.auth.uid;
    }

    /* ── Code d'accès hôpital (chantier séparé, suite à la revue de
       sécurité de la PR #1) ──
       Avant ce correctif, n'importe qui connaissant le numéro de fiche
       d'un patient pouvait créer mc_accounts/PAT_{id} avec SA PROPRE
       identité Firebase avant que le vrai patient ne s'inscrive,
       satisfaisant ensuite isConcernedPatient() à sa place (accès aux
       décisions de consentement/partage en tant que ce patient, et
       verrouillage définitif du vrai patient hors de son propre
       compte — mc_accounts.create refuse un doc déjà existant).
       mc_patients/{id}.firstAccessCode est généré par le personnel à
       la création de la fiche (js/db.js addPatient) et communiqué au
       patient hors ligne (papier, oralement) — jamais exposé par une
       règle de lecture. Le premier accès doit désormais fournir ce
       code, comparé ici au moment de la création du compte.
       Rétro-compatible : les fiches créées avant ce chantier n'ont pas
       ce champ, donc aucun code n'est exigé pour elles (défaut
       permissif, même logique que accountStatusOk()/
       hospitalSubscriptionOk()).
       Correctif (course create-fiche / premier-accès) : le document
       mc_patients/{id} doit exister pour que le code soit vérifié. Un
       !exists() en tête de clause serait AUSSI vrai juste après la
       création d'une fiche (écriture Firestore asynchrone, cf.
       js/db.js addPatient) — ça revenait à accepter n'importe quel
       code (y compris vide) pendant cette fenêtre, vidant la
       protection anti-préemption. Un identifiant ne correspondant à
       AUCUNE fiche doit être refusé, pas laissé passer. */
    // Correctif P0 (audit "workflows mobile/desktop") : la fiche
    // pouvait auparavant être considérée "à jour" (code accepté)
    // même quand mc_patients/{id}.firstAccessCode n'existait pas —
    // ancien comportement voulu pour les fiches historiques créées
    // avant ce champ, mais qui rouvrait la préemption pour TOUTE
    // fiche sans code (un tiers connaissant juste le numéro MC-xxx
    // pouvait créer le compte sans code). Un code absent sur la
    // fiche refuse désormais la création — les fiches historiques
    // sans code nécessitent une migration administrative dédiée
    // (backfill manuel du champ, hors de cette règle), jamais un
    // contournement silencieux ici.
    function patientFirstAccessOk(patientMcId, submittedCode) {
      return patientMcId == null ||
        (exists(/databases/$(database)/documents/mc_patients/$(patientMcId)) &&
         get(/databases/$(database)/documents/mc_patients/$(patientMcId)).data.get('firstAccessCode', null) != null &&
         get(/databases/$(database)/documents/mc_patients/$(patientMcId)).data.get('firstAccessCode', null) == submittedCode);
    }

    function canReadMedicalData(data) {
      return isAdmin() ||
        ownsPatientData(data) ||
        doctorCanRead(data) ||
        nurseCanRead(data);
    }

    function publicUserRole(role) {
      // 'hospital' : compte d'établissement (connexion desktop par
      // matricule). 'lab'/'reception' : agents hospitaliers desktop.
      // Tous auto-créés en statut 'pending', validés par l'admin
      // comme les autres inscriptions professionnelles.
      return role in ['patient', 'doctor', 'nurse', 'pharmacist', 'hospital', 'lab', 'reception'];
    }

    // PARTIE B — 'pin' ajouté : garde-fou contre toute réintroduction
    // future d'un PIN patient en clair (ou d'un hash local non salé/
    // faible) dans un document — Firebase Auth est désormais la seule
    // source de vérité pour le PIN (voir js/auth.js).
    function hasNoSecretFields(data) {
      return !data.keys().hasAny(['admin', 'password', 'passwordHash', 'pin']);
    }

    function visiblePharmacyProfile(data) {
      return data.role == 'pharmacist' &&
        data.isLocationVisible == true &&
        data.status in ['active', 'approved'];
    }

    function safeSelfUserCreate(uid) {
      return ownsUid(uid) &&
        request.resource.data.uid == uid &&
        publicUserRole(request.resource.data.role) &&
        request.resource.data.status == 'pending' &&
        hasNoSecretFields(request.resource.data);
    }

    function safeSelfUserUpdate(uid) {
      return ownsUid(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        hasNoSecretFields(request.resource.data);
    }

    /* Correctif (audit) : establishments/hospitals/mc_hospitals
       n'avaient QUE `allow write/create: if isAdmin()` — le compte
       hôpital non-admin qui vient de s'inscrire (hospital-auth.js
       register()) ne pouvait donc jamais faire aboutir la création de
       son propre document (échec silencieux, jamais rejoué avec
       succès). Miroir de safeSelfUserCreate : l'établissement crée SON
       PROPRE document (authUid == soi-même), statut figé à 'pending'
       (validation admin obligatoire), sans champ secret (voir
       hasNoSecretFields — interdit notamment l'ancien passwordHash en
       clair, désormais remplacé par Firebase Auth). */
    function establishmentSelfCreateOk(data) {
      return signedIn() &&
        data.get('authUid', null) == request.auth.uid &&
        data.get('status', null) == 'pending' &&
        hasNoSecretFields(data);
    }
    /* Update self-service restreint à 2 cas : (a) l'établissement met à
       jour SON PROPRE document déjà réclamé (authUid inchangé), (b) un
       établissement hérité (créé avant ce correctif, authUid absent)
       réclame son document lors de la migration organique du mot de
       passe (migrateLegacyEstablishmentAuth, js/hospital-auth.js) — le
       statut ne peut jamais changer par cette voie (auto-approbation
       impossible), et authUid ne peut jamais être réattribué à un tiers
       une fois posé. */
    function establishmentSelfClaimOk(data) {
      return signedIn() &&
        data.get('authUid', null) == request.auth.uid &&
        (resource.data.get('authUid', null) == null || resource.data.get('authUid', null) == request.auth.uid) &&
        data.get('status', null) == resource.data.get('status', null) &&
        hasNoSecretFields(data);
    }

    match /users/{uid} {
      allow create: if isAdmin() || safeSelfUserCreate(uid);
      allow read: if isAdmin() ||
        ownsUid(uid) ||
        visiblePharmacyProfile(resource.data);
      allow update: if isAdmin() || safeSelfUserUpdate(uid);
      // Correctif (chantier "suppression de compte") : le propriétaire
      // peut désormais supprimer son propre document, en plus de
      // isAdmin() — première brique de la suppression de compte
      // self-service (js/auth.js Auth._confirmDeleteMyAccount).
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /patients/{patientId} {
      allow read: if canReadMedicalData(resource.data);
      // Création bloquée si abonnement expiré/suspendu — confirmé :
      // c'est la SEULE action que le mobile/PWA bloque aussi (voir
      // hospitalCanWrite, sans distinction de plateforme ici).
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse')) &&
         (isEmergencyIntake(request.resource.data) ||
          hospitalCanWrite(resolveHospitalId(request.resource.data)))) ||
        // Correctif (section 4) : miroir exact de la clause ajoutée
        // ci-dessous sur /mc_patients (collection réellement lue) —
        // /patients (miroir) doit rester acceptée pour ne pas faire
        // échouer le batch atomique DB.addPatientAndConfirmAtomic().
        (receptionPatientCreateOk(request.resource.data) &&
         belongsToSameEstablishment(request.resource.data) &&
         (isEmergencyIntake(request.resource.data) ||
          hospitalCanWrite(resolveHospitalId(request.resource.data))));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data);
    }

    match /doctors/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'doctor' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /nurses/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'nurse' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /pharmacies/{uid} {
      allow read: if isAdmin() ||
        ownsUid(uid) ||
        (
          resource.data.isLocationVisible == true &&
          resource.data.status in ['active', 'approved']
        );
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'pharmacist' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin() || ownsUid(uid);
    }

    match /hospitals/{hospitalId} {
      allow read: if signedIn() && (
        resource.data.status in ['active', 'approved'] ||
        uidIn(resource.data.staffUids) ||
        resource.data.owner_uid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAdmin() || establishmentSelfCreateOk(request.resource.data);
      allow update: if isAdmin() || establishmentSelfClaimOk(request.resource.data);
      allow delete: if isAdmin();
    }

    // Correctif (audit "workflows mobile/desktop", section 6) : bug
    // confirmé — la clause reception de medical_records.create vérifiait
    // seulement type=='patient_record' et l'appartenance, mais
    // n'interdisait AUCUN autre champ : un document portant en plus
    // diagnosis/allergies/chronic/treatment/prescription/consultation/
    // labResults/doctorNotes/medicalHistory aurait été accepté tant que
    // type restait 'patient_record'. keys().hasOnly() sur l'ensemble
    // exact posé par DB.addPatientAndConfirmAtomic (voir js/db.js)
    // ferme cette faille — la réception ne peut plus jamais poser un
    // champ clinique, quel qu'il soit. created_by doit en plus
    // correspondre à l'auteur réel de l'écriture (anti-usurpation,
    // même principe que messageSenderIdentityOk ailleurs).
    function receptionMedicalRecordCreateOk(data) {
      return hasRole('reception') &&
        belongsToSameEstablishment(data) &&
        data.get('type', null) == 'patient_record' &&
        data.get('status', null) == 'active' &&
        data.get('created_by', null) == request.auth.uid &&
        data.keys().hasOnly([
          'recordId', 'patientId', 'patientUid', 'created_by',
          'establishmentId', 'type', 'status', 'createdAt', 'updatedAt'
        ]);
    }

    match /medical_records/{recordId} {
      allow read: if canReadMedicalData(resource.data);
      // Correctif (section 4) : la réception ne peut créer QUE le
      // document RACINE posé à la création d'une fiche (type
      // 'patient_record', voir DB.addPatient/addPatientAndConfirmAtomic)
      // — jamais un contenu clinique. La modification ultérieure (update)
      // reste réservée à doctor/nurse/admin (clause existante ci-dessous,
      // inchangée) : la réception ne modifie jamais le contenu clinique
      // après création.
      allow create: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse') ||
        receptionMedicalRecordCreateOk(request.resource.data);
      // Correctif (section 6, point 5) : la réception ne doit jamais
      // pouvoir MODIFIER le contenu clinique une fois la fiche créée —
      // seuls doctor/nurse/admin peuvent mettre à jour ce document
      // (doctorCanRead couvre déjà ces rôles cliniques ; reception n'y
      // figure jamais).
      allow update, delete: if isAdmin() || doctorCanRead(resource.data);
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAdmin() ||
        ownsPatientData(resource.data) ||
        doctorCanRead(resource.data) ||
        pharmacyCanReadPrescription(resource.data);
      allow create: if isAdmin() ||
        (currentRoleIs('doctor') &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // La pharmacie ciblée peut toujours mettre à jour le statut
      // même abonnement expiré/suspendu (une ordonnance déjà envoyée
      // doit pouvoir être honorée). Le médecin auteur reste soumis au
      // contrôle desktop/mobile pour tout envoi (dépôt patient comme
      // dispatch pharmacie) — décision produit : sur desktop expiré
      // l'envoi est bloqué des deux côtés ; le mobile n'est jamais
      // coupé (hospitalCanWriteFromDevice). Périmètre aligné sur la
      // collection canonique mc_prescriptions.
      // PARTIE H — le pharmacien ne peut modifier QUE le statut et les
      // métadonnées de traitement, jamais le contenu médical
      // (patient_id, doctor_uid, diagnosis, medicines, establishmentId,
      // pharmacyUid, date) : sans ça, un pharmacien pouvait réécrire
      // n'importe quel champ, y compris falsifier l'auteur ou le
      // diagnostic d'une ordonnance déjà envoyée.
      allow update: if isAdmin() ||
        (pharmacyCanReadPrescription(resource.data) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'updatedAt', 'updatedByUid', 'updatedByRole', 'cancelReason'])) ||
        (doctorCanRead(resource.data) &&
         hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.get('sourceDevice', null)));
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') || ownsPatientData(request.resource.data)) &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data) || ownsPatientData(resource.data);
    }

    match /notifications/{notificationId} {
      // Correctif (audit) : deux fonctions écrivent réellement cette
      // collection avec des noms de champs différents —
      // js/db.js saveMessages() (miroir mc_messages) pose to_id/to_role,
      // js/cloud-db.js createNotification() (ex. hospital-reception.js
      // "patient orienté au médecin") pose toUid/recipientUserId. Cette
      // seconde forme n'était couverte par AUCUNE des 3 clés vérifiées
      // ici : les notifications qu'elle crée restaient structurellement
      // illisibles par leur destinataire non-admin. Ajout ADDITIF des 2
      // clés manquantes, sans retirer les 3 existantes. .get(clé, null)
      // partout (au lieu de l'accès pointé direct) : un document qui ne
      // porte qu'UN sous-ensemble de ces 5 clés optionnelles levait
      // sinon une erreur d'évaluation sur les clés absentes.
      allow read, update: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.get('to_id', null) == request.auth.uid ||
            resource.data.get('recipientUid', null) == request.auth.uid ||
            resource.data.get('userUid', null) == request.auth.uid ||
            resource.data.get('toUid', null) == request.auth.uid ||
            resource.data.get('recipientUserId', null) == request.auth.uid
          )
        );
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /registration_requests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() ||
        (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /establishments/{establishmentId} {
      allow read: if signedIn();
      allow create: if isAdmin() || establishmentSelfCreateOk(request.resource.data);
      allow update: if isAdmin() || establishmentSelfClaimOk(request.resource.data);
      allow delete: if isAdmin();
    }

    /* PARTIE G/E — trace/audit des documents médicaux par établissement.
       Lecture : admin, auteur, ou membre actif du même établissement
       (PARTIE E — remplace l'ancien signedIn() trop large, qui donnait
       accès à tout utilisateur connecté sans lien avec l'hôpital).
       L'écriture reste réservée à l'auteur ou à l'admin, jamais
       modifiable après coup. */
    match /establishment_documents/{documentId} {
      allow read: if isAdmin() ||
        (signedIn() && resource.data.doctorUid == request.auth.uid) ||
        belongsToSameEstablishment(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.doctorUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /affiliation_requests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Correctif (audit sécurité, section 9) : admin_hospital peut
      // désormais lire les demandes de SON établissement (nécessaire
      // pour afficher la file "Demandes d'affiliation en attente" du
      // tableau de bord desktop) — ajout ADDITIF, jamais en remplacement
      // du droit déjà existant du demandeur sur sa propre demande.
      allow read: if isAdmin() ||
        (signedIn() && resource.data.requesterUid == request.auth.uid) ||
        canManageAffiliation(resource.data);
      // Correctif (audit sécurité, section 9) : seul isAdmin() pouvait
      // mettre à jour ce document — un admin_hospital qui approuvait/
      // refusait une demande depuis le tableau de bord desktop hôpital
      // (bouton visible côté interface) voyait systématiquement
      // l'écriture rejetée par Firestore. admin_hospital ne peut décider
      // que pour SON établissement, uniquement depuis 'pending', vers
      // 'approved'/'rejected', et seulement les champs de décision —
      // jamais requesterUid/requesterRole/establishmentId.
      allow update: if isAdmin() ||
        (canManageAffiliation(resource.data) &&
         resource.data.get('status', 'pending') == 'pending' &&
         request.resource.data.get('status', null) in ['approved', 'rejected'] &&
         affiliationDecisionFieldsOk(resource.data, request.resource.data) &&
         request.resource.data.get('decidedByUid', null) == request.auth.uid &&
         currentRoleIs(request.resource.data.get('decidedByRole', '')));
      allow delete: if isAdmin();
    }

    /* PARTIE B/C — mc_accounts reste en lecture publique (nécessaire
       au lookup pré-authentification par numéro pro/patient : fermer
       ça casserait la connexion de tout le personnel — voir
       docs/FIREBASE_KEY_SECURITY.md). Le vrai correctif porte sur ce
       qui PEUT y être écrit : hasNoSecretFields interdit désormais
       tout champ password/pin/passwordHash, y compris ici (absent
       jusqu'ici) — le PIN patient est géré exclusivement par Firebase
       Authentication (js/auth.js), jamais stocké en clair ni haché
       localement dans ce document public. */
    // Correctif (revue de sécurité) : rien n'empêchait de poser un
    // authUid arbitraire (potentiellement celui d'un tiers) sur un
    // nouveau document — un attaquant connaissant un numéro de fiche
    // patient pouvait ainsi préempter mc_accounts/PAT_{id} avec SON
    // PROPRE authUid avant que le vrai patient ne crée son compte, et
    // satisfaire ensuite isConcernedPatient() à sa place. On exige
    // désormais que authUid, quand il est posé, corresponde à
    // l'utilisateur réellement connecté qui écrit — pas de contrainte
    // signedIn() globale ici : l'inscription professionnelle en mode
    // dégradé (Firebase Auth indisponible, cf. js/auth.js
    // _createFirebaseUser) écrit encore mc_accounts SANS authUid, et ce
    // repli existant ne doit pas casser.
    // Correctif (chantier "code d'accès hôpital") : la limite ci-dessus
    // (préemption d'une fiche patient avec sa PROPRE identité Firebase)
    // est désormais fermée pour les comptes patient par
    // patientFirstAccessOk() — la création exige le code communiqué
    // hors ligne par l'hôpital à la création de la fiche (voir
    // js/db.js addPatient / js/hospital.js showFirstAccessCodeModal),
    // pas seulement la connaissance du numéro MC-xxx.
    //
    // Correctif (audit sécurité, chantier "reception/affiliation sans
    // régression") : la clause create ci-dessus ne restreignait AUCUNEMENT
    // le champ role — un utilisateur (même non authentifié, voir le mode
    // dégradé ci-dessous) pouvait poser role:'admin' ou
    // role:'admin_hospital' sur un nouveau document. scripts/sync-
    // account-security.mjs lit ce même rôle pour poser un VRAI custom
    // claim Firebase Auth (admin:true) sur les comptes approuvés/actifs —
    // ce document forgé pouvait donc aboutir à une élévation de privilège
    // réelle. Fermé ADDITIVEMENT ci-dessous, sans toucher à la logique
    // existante des rôles déjà admis (doctor/nurse/pharmacist/lab/
    // reception/patient) ni au mode dégradé déjà toléré et testé
    // (tests/firestore-rules/mc-accounts.rules.test.js).
    match /mc_accounts/{docId} {
      allow read: if true;
      // 'hospital' inclus pour cohérence avec le reste du produit, même
      // si aucun code actuel n'écrit ce rôle dans mc_accounts (le compte
      // établissement vit dans users/{authUid}, pas ici) — inoffensif.
      // 'admin' et 'admin_hospital' SONT VOLONTAIREMENT ABSENTS : aucune
      // inscription ordinaire ne doit jamais pouvoir se les attribuer.
      function selfRegistrableProfessionalRole(role) {
        return role in ['doctor', 'nurse', 'pharmacist', 'hospital', 'lab', 'reception'];
      }
      // Cas strict : identité Firebase Auth réelle de bout en bout —
      // toujours le cas pour lab/reception (js/auth.js _regAgentStrict,
      // aucun mode dégradé), et pour doctor/nurse/pharmacist quand la
      // création Firebase Auth a réussi (js/auth.js _reg/_createFirebaseUser).
      function validMcAccountSelfCreate(id, data) {
        return signedIn() &&
          data.get('authUid', null) == request.auth.uid &&
          data.get('uid', null) == request.auth.uid &&
          id == request.auth.uid &&
          selfRegistrableProfessionalRole(data.get('role', '')) &&
          data.get('status', null) == 'pending' &&
          hasNoSecretFields(data);
      }
      // Cas hérité ("mode dégradé", js/auth.js _reg/_createFirebaseUser) :
      // doctor/nurse/pharmacist SANS identité Firebase Auth (échec réseau
      // ou autre à la création) — comportement DÉJÀ existant et DÉJÀ
      // testé (mc-accounts.rules.test.js, "création SANS secret ET sans
      // authUid... est acceptée"), y compris sans signedIn(). Jamais
      // utilisé par lab/reception. Resserré au strict nécessaire pour
      // fermer la vraie faille : rôle borné (jamais admin/admin_hospital),
      // statut toujours 'pending'.
      function legacyDegradedProfessionalCreate(data) {
        return data.get('authUid', null) == null &&
          data.get('role', '') in ['doctor', 'nurse', 'pharmacist'] &&
          data.get('status', null) == 'pending' &&
          hasNoSecretFields(data);
      }
      // Cas patient — Correctif P0 (audit "workflows mobile/desktop") :
      // patient_id était seulement optionnel ici (data.get(...,null)),
      // et patientFirstAccessOk(null, ...) renvoie vrai par construction
      // (branche dédiée aux comptes PROFESSIONNELS, qui n'ont pas de
      // patient_id) — un compte role:'patient' pouvait donc être créé
      // SANS patient_id du tout, contournant entièrement le code de
      // premier accès. On exige désormais, pour ce cas précis, un
      // patient_id non vide, un docId de la forme PAT_{patient_id} (le
      // format déjà utilisé par js/auth.js _createPatientPin), un uid
      // cohérent, et un authUid réel et obligatoire (déjà le
      // comportement de l'app cliente, cf. js/auth.js : la création est
      // refusée côté client si Firebase Auth n'a pas pu créer le
      // compte — aucun mode dégradé patient à préserver ici).
      function validPatientAccountSelfCreate(id, data) {
        return data.get('role', '') == 'patient' &&
          data.get('patient_id', null) is string &&
          data.get('patient_id', null).size() > 0 &&
          id == 'PAT_' + data.get('patient_id', null) &&
          data.get('uid', null) == id &&
          signedIn() &&
          data.get('authUid', null) == request.auth.uid &&
          hasNoSecretFields(data);
      }
      allow create: if !exists(/databases/$(database)/documents/mc_accounts/$(docId)) &&
        patientFirstAccessOk(request.resource.data.get('patient_id', null), request.resource.data.get('firstAccessCode', null)) &&
        (
          isAdmin() ||
          validMcAccountSelfCreate(docId, request.resource.data) ||
          legacyDegradedProfessionalCreate(request.resource.data) ||
          validPatientAccountSelfCreate(docId, request.resource.data)
        );
      // Correctif (chantier "durcissement sans Cloud Functions") :
      // contrairement à users/doctors/nurses/pharmacies
      // (safeSelfUserUpdate/status ET rôle figés sauf isAdmin()), cette
      // règle n'imposait PAS l'immuabilité du statut — un professionnel
      // dont les écritures secondaires (users/{uid}, collection de
      // rôle) échouent (hors-ligne, rôle lab/reception sans collection
      // dédiée) pouvait, dans ce cas précis, forger lui-même
      // mc_accounts.status = 'approved'. Même contrainte que les
      // autres collections de compte : status ET role figés sauf isAdmin().
      // Correctif (chantier lab/reception, spec §11 point 50) : le rôle
      // seul n'était pas encore protégé ici (contrairement à
      // safeSelfUserUpdate, qui gèle déjà request.resource.data.role) —
      // un compte lab/reception approuvé aurait pu changer son propre
      // rôle (ex. vers 'doctor') sans jamais toucher au statut.
      // Correctif (audit sécurité) : authUid/uid/patient_id/
      // professionalNumber/matricule n'étaient pas encore figés — un
      // propriétaire pouvait en théorie réécrire ces champs d'identité
      // après création. Ajout ADDITIF, même principe.
      function mcAccountImmutableFieldsOk(before, after) {
        return after.get('status', null) == before.get('status', null) &&
          after.get('role', null) == before.get('role', null) &&
          after.get('authUid', null) == before.get('authUid', null) &&
          after.get('uid', null) == before.get('uid', null) &&
          after.get('patient_id', null) == before.get('patient_id', null) &&
          after.get('professionalNumber', null) == before.get('professionalNumber', null) &&
          after.get('matricule', null) == before.get('matricule', null);
      }
      allow update: if hasNoSecretFields(request.resource.data) && (
        isAdmin() ||
        ((signedIn() && request.auth.uid == docId) &&
         mcAccountImmutableFieldsOk(resource.data, request.resource.data)) ||
        ((signedIn() && resource.data.get('authUid', null) == request.auth.uid) &&
         mcAccountImmutableFieldsOk(resource.data, request.resource.data))
      );
      // Correctif (chantier "suppression de compte") : le propriétaire
      // peut supprimer son propre document mc_accounts — cas pro
      // (docId == uid) et cas patient (docId == 'PAT_{id}', identifié
      // via authUid, comme pour update ci-dessus).
      allow delete: if isAdmin() ||
        (signedIn() && request.auth.uid == docId) ||
        (signedIn() && resource.data.get('authUid', null) == request.auth.uid);
    }

    match /mc_verified_doctors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_verified_pharms/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_verified_nurses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_consultations/{docId} {
      // PARTIE E : l'ancien "currentRoleIs('doctor') || currentRoleIs('nurse')"
      // sans filtre établissement laissait n'importe quel médecin/
      // infirmier lire TOUTE la collection, y compris d'autres hôpitaux
      // — remplacé par belongsToSameEstablishment (aucun consentement
      // requis pour l'établissement créateur, clarification client).
      // subscriptionReadGateOk : une consultation créée côté desktop
      // n'est visible au médecin/infirmier(ère) que si l'abonnement de
      // l'établissement est actif (voir définition plus haut) — jamais
      // appliqué au patient (ownsPatientData reste inconditionnel).
      // Correctif (chantier sécurité, section 9/10) : belongsToSameEstablishment()
      // seule donnait à TOUT membre actif de l'établissement — y
      // compris reception et lab, sans capacité client correspondante —
      // un accès en lecture au contenu clinique complet. Resserré à
      // isClinicalHospitalMember() (doctor/nurse/admin_hospital
      // uniquement).
      allow read: if (canReadMedicalData(resource.data) ||
        isClinicalHospitalMember(resource.data)) &&
        subscriptionReadGateOk(resource.data);
      // Créer/valider une consultation = acte médical : médecin
      // uniquement (l'infirmier peut lire, pas créer). Verrouillage
      // serveur du contrôle de capacité côté client.
      // Correctif (audit) : le principe documenté plus haut
      // (hospitalCanWriteFromDevice — mobile jamais coupé, desktop
      // bloqué si abonnement expiré) n'était en réalité JAMAIS
      // appliqué ici : seule la collection jumelle /consultations
      // (jamais lue en pratique par l'app, mirror mort) avait cette
      // clause. Le vrai chemin d'écriture (js/db.js addConsultation)
      // pouvait donc créer des consultations indéfiniment sur
      // desktop, abonnement expiré ou non.
      allow create: if canDecideMedical() &&
        hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice);
      allow update: if canDecideMedical() &&
        hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice);
      allow delete: if canDecideMedical();
    }

    match /mc_vaccinations/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
    }

    match /mc_lab_results/{docId} {
      // subscriptionReadGateOk : un résultat de labo créé côté desktop
      // n'est visible au médecin/infirmier(ère) que si l'abonnement de
      // l'établissement est actif (jamais appliqué au patient, ni au
      // laborantin/admin_hospital qui traitent la demande).
      // Correctif (chantier sécurité, section 9/10) : lab (son propre
      // résultat, légitime) ET clinique (doctor/nurse/admin_hospital) —
      // jamais reception (belongsToSameEstablishment() seule le
      // permettait avant ce correctif).
      allow read: if (canReadMedicalData(resource.data) ||
        isClinicalHospitalMember(resource.data) || labCanReadLabData(resource.data)) &&
        subscriptionReadGateOk(resource.data);
      // Correctif (chantier "modales laboratoire") : "allow write" sans
      // aucune autre condition permettait à un laborantin (ou médecin/
      // infirmier) de N'IMPORTE QUEL hôpital de créer/modifier/
      // supprimer le miroir patient mc_lab_results de N'IMPORTE QUEL
      // AUTRE établissement — aucune isolation par établissement
      // n'était appliquée ici (contrairement à labRequests/labResults
      // ci-dessus, dont c'était déjà l'objet). Resserré au même
      // principe : rôle habilité + affilié à l'établissement de la
      // fiche ; aucune modification/suppression après création (miroir
      // patient, jamais réécrit par l'app une fois émis).
      allow create: if isAdmin() ||
        (canEnterLabResult() &&
         belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)) &&
         request.resource.data.get('created_by', null) == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Correctif (audit) : miroir patient de la collection desktop
    // `admissions` (patientMc, jamais lue par le patient) — sans lui,
    // le filtre "🏥 Hospitalisation" du dossier patient
    // (js/timeline.js) n'était jamais alimenté. Écrit par
    // hospital-beds.js/hospital-reception.js (doctor/nurse/reception/
    // admin_hospital, mêmes rôles que canRegisterPatient()).
    // Correctif (audit sécurité) : "allow write" n'exigeait que le rôle,
    // aucune isolation par établissement — un médecin/infirmier/
    // réceptionniste/admin_hospital réellement affilié à l'hôpital A
    // pouvait créer, modifier ou SUPPRIMER une admission de l'hôpital B
    // (vérifié en conditions réelles sur l'émulateur). Ajout ADDITIF de
    // belongsToSameEstablishment, même principe que mc_lab_results ci-
    // dessus. "write" scindé en create/update (request.resource.data,
    // hôpital CIBLE) et update/delete (resource.data, hôpital existant)
    // car resource.data n'existe pas encore à la création.
    match /mc_admissions/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') ||
          hasRole('reception') || hasRole('admin_hospital')) &&
         belongsToSameEstablishment(request.resource.data));
      allow update, delete: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') ||
          hasRole('reception') || hasRole('admin_hospital')) &&
         belongsToSameEstablishment(resource.data));
    }

    // Correctif (audit) : miroirs patient des collections desktop
    // emergencyCases/maternityCases (patientMc, jamais lues par le
    // patient) — même principe que mc_lab_results/mc_admissions.
    // Écrits par hospital-emergency.js/hospital-maternity.js, gatés
    // côté client par guardHospitalAction('view_patient'/'create_patient'),
    // mêmes rôles que canRegisterPatient().
    // Correctif (audit sécurité) : même faille d'isolation que
    // mc_admissions ci-dessus (aucun belongsToSameEstablishment) —
    // corrigée de façon identique.
    match /mc_emergency_cases/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') ||
          hasRole('reception') || hasRole('admin_hospital')) &&
         belongsToSameEstablishment(request.resource.data));
      allow update, delete: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') ||
          hasRole('reception') || hasRole('admin_hospital')) &&
         belongsToSameEstablishment(resource.data));
    }

    match /mc_maternity_cases/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') ||
          hasRole('reception') || hasRole('admin_hospital')) &&
         belongsToSameEstablishment(request.resource.data));
      allow update, delete: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') ||
          hasRole('reception') || hasRole('admin_hospital')) &&
         belongsToSameEstablishment(resource.data));
    }

    match /mc_medicines/{docId} {
      // Catalogue public inchangé (spec explicite) : la lecture reste
      // ouverte à tout compte connecté (js/map.js — disponibilité des
      // médicaments par pharmacie). Seule l'ÉCRITURE est isolée.
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (currentRoleIs('pharmacist') && request.resource.data.get('pharmacyUid', null) == request.auth.uid);
      allow update, delete: if isAdmin() || pharmacyOwnsOrLegacy(resource.data);
    }

    match /mc_sales/{docId} {
      // Correctif (chantier sécurité, section 11) : bug confirmé — tout
      // pharmacien pouvait lire/modifier/supprimer les ventes de
      // N'IMPORTE QUEL autre pharmacien (aucune isolation). Repli legacy
      // documenté pour les ventes créées avant pharmacyUid.
      allow read: if isAdmin() || pharmacyOwnsOrLegacy(resource.data);
      allow create: if isAdmin() ||
        (currentRoleIs('pharmacist') && request.resource.data.get('pharmacyUid', null) == request.auth.uid);
      allow update, delete: if isAdmin() || pharmacyOwnsOrLegacy(resource.data);
    }

    /* PARTIE D — un utilisateur connecté quelconque pouvait auparavant
       créer/lire/modifier N'IMPORTE QUEL consentement (allow read/write:
       if signedIn()). Resserré : seul le médecin demandeur peut créer
       SA demande (statut initial 'pending' imposé) ; lecture réservée
       au patient concerné, au médecin demandeur, ou à l'admin ; seul
       le patient concerné peut approuver/refuser/révoquer (champs
       limités à status/decided_at/expires_at/updated_at) ; le médecin
       demandeur peut uniquement révoquer sa propre demande, jamais
       l'approuver lui-même. RAPPEL (clarification client) : ce
       mécanisme ne sert JAMAIS à l'accès de l'établissement créateur
       de la fiche (voir belongsToSameEstablishment) — uniquement aux
       accès externes explicitement demandés par un médecin. */
    match /mc_consents/{docId} {
      allow read: if isAdmin() ||
        isConcernedPatient(resource.data.patient_id) ||
        (signedIn() && resource.data.doctor_id == request.auth.uid);
      allow create: if isAdmin() ||
        (signedIn() &&
         request.resource.data.doctor_id == request.auth.uid &&
         request.resource.data.status == 'pending' &&
         request.resource.data.patient_id is string &&
         request.resource.data.patient_id != '');
      allow update: if isAdmin() ||
        (isConcernedPatient(resource.data.patient_id) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'decided_at', 'expires_at', 'updated_at'])) ||
        (signedIn() && resource.data.doctor_id == request.auth.uid &&
         request.resource.data.status == 'revoked' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'decided_at', 'updated_at']));
      allow delete: if isAdmin();
    }

    match /mc_patients/{docId} {
      // PARTIE E : remplace l'ancien "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" (accès à TOUTE la collection, y compris
      // d'autres établissements) par belongsToSameEstablishment — le
      // cas central de la clarification client : le médecin/infirmier
      // membre de l'établissement CRÉATEUR de la fiche y accède SANS
      // consentement (mc_consents ne sert qu'aux accès externes).
      allow read: if canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data);
      // Correctif (trouvé en répondant à une question client, jamais
      // testé à la création jusqu'ici) : cette collection, pourtant
      // canonique (lue par _doPatient/_createPatientPin pour retrouver
      // une fiche depuis un autre appareil que celui qui l'a créée),
      // n'avait AUCUNE clause de création pour le personnel non-admin
      // — seul `allow write: if isAdmin()` existait. Un(e)
      // infirmier/médecin ne pouvait donc jamais faire aboutir
      // DB.addPatient() ici (échec silencieux, mis en file d'attente
      // indéfiniment). Miroir exact de la clause déjà en place sur la
      // collection sœur /patients (ligne ~389).
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse')) &&
         (isEmergencyIntake(request.resource.data) ||
          hospitalCanWrite(resolveHospitalId(request.resource.data)))) ||
        // Correctif (chantier sécurité, section 4) : bug confirmé — la
        // matrice client autorise déjà la réception à créer un patient
        // (js/hospital-capabilities.js), mais AUCUNE clause create ne
        // couvrait ce rôle ici ; la fiche restait provisoire, jamais
        // confirmée par Firestore. receptionPatientCreateOk() limite le
        // document à des champs administratifs — jamais de contenu
        // clinique.
        (receptionPatientCreateOk(request.resource.data) &&
         belongsToSameEstablishment(request.resource.data) &&
         (isEmergencyIntake(request.resource.data) ||
          hospitalCanWrite(resolveHospitalId(request.resource.data))));
      allow update, delete: if isAdmin();
    }

    /* ── Correctif (audit "workflows mobile/desktop", section 7) ──────
       Bug confirmé : réception et laboratoire n'ont aujourd'hui aucun
       autre moyen d'identifier un patient que de lire mc_patients — un
       document CLINIQUE complet (diagnostic, allergies, antécédents…)
       — alors que leur rôle n'a besoin que d'une identité
       administrative minimale. patient_directory est un miroir réduit,
       alimenté dans le MÊME batch atomique que mc_patients/patients/
       medical_records (voir DB.addPatientAndConfirmAtomic), qui ne
       contient jamais de contenu clinique — keys().hasOnly() l'impose
       côté serveur, pas seulement par convention côté client.
       Limite actuelle (voir rapport final) : la recherche réelle de
       réception/laboratoire (js/hospital-reception.js,
       js/hospital-lab.js) continue de lire mc_patients directement —
       cette collection est disponible en lecture pour ces deux rôles
       dès maintenant, mais la migration du CODE de recherche vers
       patient_directory est un chantier distinct et progressif (spec
       section 7, point 9), pour ne jamais casser la recherche
       existante avant d'avoir validé la migration des données
       historiques (script dédié, voir scripts/backfill-patient-
       directory.mjs). */
    function patientDirectoryFieldsOk(data) {
      return data.keys().hasOnly([
        'patientId', 'firstname', 'lastname', 'dob', 'gender', 'phone',
        'establishmentId', 'hospital_id', 'administrativeStatus',
        'createdAt', 'updatedAt'
      ]);
    }
    match /patient_directory/{docId} {
      allow read: if isAdmin() ||
        isClinicalHospitalMember(resource.data) ||
        (hasRole('reception') && belongsToSameEstablishment(resource.data)) ||
        (hasRole('lab') && belongsToSameEstablishment(resource.data));
      allow create: if isAdmin() ||
        (patientDirectoryFieldsOk(request.resource.data) &&
         ((currentRoleIs('doctor') || currentRoleIs('nurse')) &&
          (isEmergencyIntake(request.resource.data) ||
           hospitalCanWrite(resolveHospitalId(request.resource.data)))) ||
         (patientDirectoryFieldsOk(request.resource.data) &&
          hasRole('reception') && belongsToSameEstablishment(request.resource.data) &&
          (isEmergencyIntake(request.resource.data) ||
           hospitalCanWrite(resolveHospitalId(request.resource.data)))));
      allow update: if isAdmin() ||
        (patientDirectoryFieldsOk(request.resource.data) &&
         (currentRoleIs('doctor') || currentRoleIs('nurse')) &&
         belongsToSameEstablishment(resource.data));
      allow delete: if isAdmin();
    }

    match /mc_prescriptions/{docId} {
      // PARTIE E : remplace l'ancien "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" (accès à TOUTE la collection, tous
      // établissements confondus) par belongsToSameEstablishment —
      // sans consentement pour l'établissement créateur (clarification
      // client), plus l'auteur direct et le pharmacien ciblé.
      // subscriptionReadGateOk : une ordonnance créée côté desktop n'est
      // visible au médecin/infirmier(ère) que si l'abonnement de
      // l'établissement est actif (jamais appliqué au patient, ni au
      // pharmacien qui la traite).
      // Correctif (chantier sécurité, section 9/10) : même resserrement
      // que mc_consultations — belongsToSameEstablishment() seule
      // donnait aussi à reception/lab un accès aux ordonnances.
      allow read: if (canReadMedicalData(resource.data) ||
        isClinicalHospitalMember(resource.data) ||
        pharmacyCanReadPrescription(resource.data)) &&
        subscriptionReadGateOk(resource.data);
      // Correctif (audit) : même défaut que mc_consultations — le
      // principe hospitalCanWriteFromDevice n'était appliqué que sur
      // la collection jumelle /prescriptions (mirror jamais lu en
      // pratique). js/db.js addPrescription pose déjà sourceDevice ;
      // il ne restait qu'à le vérifier ici.
      allow create: if isAdmin() ||
        (currentRoleIs('doctor') &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // PARTIE H — même restriction de champs que /prescriptions : le
      // pharmacien ne modifie jamais le contenu médical, uniquement le
      // statut et ses métadonnées de traitement.
      // Correctif (audit — dérive canonique/legacy) : le médecin auteur
      // pouvait modifier mc_prescriptions (collection réellement lue)
      // sans AUCUN contrôle d'abonnement, alors que la collection
      // jumelle /prescriptions gate déjà cette mise à jour via
      // hospitalCanWriteFromDevice. On aligne les deux : tout envoi
      // d'ordonnance par le médecin (dépôt patient comme dispatch
      // pharmacie) est soumis au contrôle desktop/mobile — décision
      // produit : sur desktop expiré l'envoi est bloqué des deux côtés,
      // le mobile n'est jamais coupé.
      allow update: if isAdmin()
        || (doctorCanRead(resource.data) &&
            hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.get('sourceDevice', null)))
        || (pharmacyCanReadPrescription(resource.data) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt', 'updatedByUid', 'updatedByRole', 'cancelReason']));
      allow delete: if isAdmin();
    }

    match /mc_appointments/{docId} {
      // Correctif (audit sécurité) : contrairement à mc_consultations/
      // mc_lab_results/mc_prescriptions, cette collection n'avait ni
      // l'isolation par établissement (belongsToSameEstablishment) ni
      // la passerelle d'abonnement (subscriptionReadGateOk) — même
      // principe additif que ces collections sœurs : un membre de
      // l'établissement voit les rendez-vous de ses collègues, et un
      // rendez-vous créé côté desktop n'est visible au médecin/
      // infirmier(ère) que si l'abonnement est actif (jamais pour le
      // patient, ownsPatientData reste inconditionnel via canReadMedicalData).
      allow read: if (canReadMedicalData(resource.data) ||
        belongsToSameEstablishment(resource.data)) &&
        subscriptionReadGateOk(resource.data);
      // Correctif (audit) : aucune clause create — seul isAdmin()
      // pouvait écrire, alors que DB.addAppointment() (js/db.js) est
      // appelé par un médecin/infirmier/patient normal
      // (js/appointments.js save()). Miroir exact de la clause déjà en
      // place sur la collection sœur /appointments (ligne ~541).
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') || ownsPatientData(request.resource.data)) &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data) || ownsPatientData(resource.data);
    }

    match /mc_messages/{docId} {
      allow read: if isAdmin() || (signedIn() && resource.data.to_id == request.auth.uid);
      // Correctif (chantier sécurité, section 12) : "update" acceptait
      // n'importe quel champ (corps, expéditeur, destinataire, pièce
      // jointe...) dès lors que le destinataire était le bon — un
      // destinataire pouvait donc réécrire le message reçu après coup.
      // Resserré aux seuls champs de statut de lecture/suppression
      // locale ; le contenu (body/subject/from*/to*/attachedRecord*)
      // reste IMMUABLE après création.
      allow update: if isAdmin() ||
        (signedIn() && resource.data.to_id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['readStatus', 'read', 'readAt', 'deletedFor', 'updatedAt']));
      // Correctif (audit) : seuls les messages qui portent explicitement
      // un hospitalId (messagerie pro→pro, js/transfer_ui_patch.js) sont
      // soumis à hospitalCanWriteFromDevice — les 8 autres types de
      // notification (rendez-vous, ordonnance, labo, affiliation...) ne
      // posent jamais ce champ et restent donc toujours autorisés,
      // inchangés.
      // Correctif (chantier sécurité, section 12) : aucune vérification
      // de l'identité de l'expéditeur n'existait — messageSenderIdentityOk()
      // ferme l'usurpation. Quand hospitalId est posé, exige en plus que
      // l'expéditeur soit RÉELLEMENT membre actif de cet établissement
      // (hospitalCanWriteFromDevice ne vérifiait que l'abonnement, jamais
      // l'appartenance).
      allow create: if isAdmin() ||
        (signedIn() && messageSenderIdentityOk(request.resource.data) &&
         ((!('hospitalId' in request.resource.data)) ||
          request.resource.data.hospitalId in [null, ''] ||
          (isHospitalMember(resolveHospitalId(request.resource.data)) &&
           hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data),
                                       request.resource.data.sourceDevice))));
      allow delete: if isAdmin();
    }

    match /mc_hospitals/{docId} {
      allow read: if signedIn();
      allow create: if isAdmin() || establishmentSelfCreateOk(request.resource.data);
      allow update: if isAdmin() || establishmentSelfClaimOk(request.resource.data);
      allow delete: if isAdmin();
    }

    match /mc_affiliations/{docId} {
      allow read: if isAdmin() || (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow write: if isAdmin();
    }

    /* ══════════════════════════════════════════════════
       CONTRAT D'ÉCHANGE MOBILE ↔ DESKTOP
       Chaque document porte hospitalId + createdByUid. L'écriture
       exige : membre signé, et abonnement actif/grace_period —
       vérifié côté serveur (hospitalCanWrite), pas seulement en JS.
       L'admin garde un accès de secours pour la maintenance.
    ══════════════════════════════════════════════════ */
    match /subscriptions/{hospitalId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /consultations/{docId} {
      allow read: if isAdmin() || canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    // Correctif (chantier "modales laboratoire") : AUCUNE clause create
    // ne vérifiait le rôle réel (n'importe quel compte signé pouvait
    // créer une demande d'analyse, y compris un laborantin ou un
    // patient) ; AUCUNE clause update ne restreignait ni le rôle, ni
    // l'établissement, ni les champs modifiables — un laborantin non
    // affilié à l'établissement pouvait modifier N'IMPORTE QUELLE
    // demande de N'IMPORTE QUEL hôpital, y compris ses champs
    // d'identification (patientMc, requestedByUid...).
    match /labRequests/{docId} {
      // Correctif (chantier sécurité, section 9/10) : belongsToSameEstablishment()
      // seule donnait aussi à reception l'accès aux demandes d'analyse
      // (contenu labo, hors capacités reception). Lab (labCanReadLabData)
      // et clinique (isClinicalHospitalMember) seulement.
      allow read: if canReadMedicalData(resource.data) ||
        isClinicalHospitalMember(resource.data) || labCanReadLabData(resource.data);
      allow create: if isAdmin() ||
        (canRequestLab() &&
         belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)) &&
         request.resource.data.get('status', null) == 'requested' &&
         request.resource.data.get('requestedByUid', null) == request.auth.uid &&
         currentRoleIs(request.resource.data.get('requestedByRole', '')));
      allow update: if isAdmin() ||
        (canEnterLabResult() &&
         belongsToSameEstablishment(resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(resource.data)) &&
         labRequestUpdateKeysOk(resource.data, request.resource.data) &&
         labStatusTransitionOk(resource.data.get('status', 'requested'),
                                request.resource.data.get('status', resource.data.get('status', 'requested'))));
      allow delete: if isAdmin();
    }

    match /labResults/{docId} {
      // Un laborantin/médecin de l'établissement peut consulter les
      // résultats de son hôpital (affichage desktop) ; le destinataire
      // désigné (resultRecipientUids) y accède quel que soit
      // l'établissement où il exerce habituellement.
      // Correctif (chantier sécurité, section 9/10) : même resserrement
      // que mc_lab_results — reception n'a plus accès aux résultats.
      allow read: if isAdmin() || canReadMedicalData(resource.data) ||
        isClinicalHospitalMember(resource.data) || labCanReadLabData(resource.data) ||
        uidIn(resource.data.get('resultRecipientUids', []));
      // Saisir un résultat = capacité labo/médecin ET affiliation à
      // L'ÉTABLISSEMENT DE LA DEMANDE ET abonnement actif (collection
      // desktop-only : contrôle infalsifiable, sans dépendance au champ
      // sourceDevice — voir desktopWorkflowCanWrite). completedByUid
      // doit être l'auteur réel : personne ne peut signer le résultat
      // d'un autre.
      allow create: if isAdmin() ||
        (canEnterLabResult() &&
         belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)) &&
         request.resource.data.get('completedByUid', null) == request.auth.uid);
      // Aucun chemin client ne modifie un résultat déjà émis — resserré
      // à l'admin (l'ancienne clause canEnterLabResult() permettait à
      // un laborantin non affilié de modifier le résultat d'un AUTRE
      // hôpital, sans aucune vérification d'établissement).
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /messages/{docId} {
      allow read: if isAdmin() ||
        (signedIn() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid));
      // Correctif (chantier sécurité, section 12) : même durcissement
      // que mc_messages — vérifie désormais l'identité de l'expéditeur.
      allow create: if isAdmin() ||
        (signedIn() && messageSenderIdentityOk(request.resource.data) &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && resource.data.toUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readStatus','readAt']));
      allow delete: if isAdmin();
    }

    /* PARTIE E — un membre ne peut écrire QUE son propre document
       ({hospitalId}_{son uid}, avec uid == son propre uid) : aucune
       élévation de privilège possible même en auto-guérison côté
       client (ensureHospitalMembership). L'admin garde la main pour
       l'approbation/le retrait effectués depuis le tableau de bord
       (l'acteur est alors l'admin, pas le membre lui-même).

       Correctif (revue de sécurité) : la seule contrainte docId/uid
       ci-dessus ne vérifiait PAS que l'affiliation était réellement
       approuvée — n'importe quel compte connecté qui connaît un
       hospitalId pouvait s'auto-écrire un statut "active" et obtenir
       ainsi tout l'accès belongsToSameEstablishment de cet
       établissement. hasApprovedAffiliation() exige la préexistence
       d'un affiliation_requests/AFF_{uid}_{hospitalId} au statut
       "approved" — document que seul un admin peut faire passer à ce
       statut (voir la règle affiliation_requests). L'auto-écriture
       reste donc un simple MIROIR d'un fait déjà approuvé côté
       serveur, jamais une élévation indépendante. */
    function hasApprovedAffiliation(hospitalId) {
      return hospitalId != null &&
        exists(/databases/$(database)/documents/affiliation_requests/$('AFF_' + request.auth.uid + '_' + hospitalId)) &&
        get(/databases/$(database)/documents/affiliation_requests/$('AFF_' + request.auth.uid + '_' + hospitalId)).data.status == 'approved';
    }
    match /hospitalMembers/{docId} {
      // Correctif (audit sécurité) : "signedIn()" seul laissait N'IMPORTE
      // QUEL compte connecté (patient, pharmacien, personnel d'un tout
      // autre établissement) lire l'affiliation hôpital↔personnel↔rôle
      // de n'importe qui, en devinant simplement le docId
      // ({hospitalId}_{uid}). Resserré au même principe que le reste du
      // fichier (PARTIE E) : admin, le titulaire du document lui-même, ou
      // un admin_hospital pour les membres de SON PROPRE établissement
      // (ajout ADDITIF, chantier "reception/affiliation sans régression"
      // section 9 — nécessaire pour la gestion du personnel affilié).
      allow read: if isAdmin() ||
        (signedIn() && resource.data.get('uid', null) == request.auth.uid) ||
        (hasRole('admin_hospital') && isHospitalMember(resource.data.get('hospitalId', null)));
      allow create, update: if isAdmin() ||
        (signedIn() &&
         docId == (resolveHospitalId(request.resource.data) + '_' + request.auth.uid) &&
         request.resource.data.uid == request.auth.uid &&
         request.resource.data.status == 'active' &&
         hasApprovedAffiliation(resolveHospitalId(request.resource.data))) ||
        // Correctif (audit sécurité, section 9) : sans cette clause,
        // même une fois affiliation_requests.update autorisé pour
        // admin_hospital, le batch d'approbation échouait quand même sur
        // CETTE écriture (hospitalMembers du REQUÉRANT, pas de
        // l'admin_hospital lui-même — le principe self-write seul ne
        // pouvait jamais couvrir ce cas). Un admin_hospital ne peut
        // activer que le membre d'une demande pending/approved qu'il a
        // lui-même le droit de gérer, pour SON établissement — jamais une
        // élévation indépendante d'un tiers sans dossier de demande.
        (hasRole('admin_hospital') &&
         isHospitalMember(resolveHospitalId(request.resource.data)) &&
         request.resource.data.get('status', null) == 'active' &&
         hasPendingOrApprovedAffiliationFor(request.resource.data.get('uid', null), resolveHospitalId(request.resource.data)));
      // Correctif (chantier "suppression de compte") : un membre peut
      // supprimer son propre document d'affiliation (utilisé lors de
      // la suppression de compte pour nettoyer hospitalMembers).
      allow delete: if isAdmin() || (signedIn() && resource.data.get('uid', null) == request.auth.uid);
    }

    /* ── Bundle desktop hôpital (adapté) — beds/admissions/aiQueries ──
       Correctif (audit sécurité) : "desktopWorkflowCanWrite" ne vérifie
       QUE l'abonnement de l'hôpital CIBLE, jamais que l'auteur est
       affilié à cet hôpital — vérifié en conditions réelles sur
       l'émulateur : un membre actif de l'hôpital B pouvait créer/
       modifier/supprimer des lits, admissions, dossiers d'urgence et de
       maternité de l'hôpital A. Ajout ADDITIF de
       belongsToSameEstablishment(request.resource.data) partout ici,
       même principe déjà appliqué à mc_lab_results/mc_admissions. */
    match /beds/{docId} {
      // Correctif (audit "workflows mobile/desktop", section 18) :
      // "signedIn()" seul laissait N'IMPORTE QUEL utilisateur connecté
      // (même d'un autre établissement, même lab/pharmacist) lire TOUS
      // les lits de la plateforme. careCoordinationCanRead() restreint
      // à la coordination des soins de l'établissement concerné.
      allow read: if isAdmin() || careCoordinationCanRead(resource.data);
      allow create, update: if isAdmin() ||
        (signedIn() && belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /admissions/{docId} {
      // PARTIE E : remplace le "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" non filtré (accès inter-établissements)
      // par belongsToSameEstablishment.
      // Correctif (audit "workflows mobile/desktop", section 18) :
      // belongsToSameEstablishment() SEULE rouvrait cet accès à
      // lab/pharmacist (aucune capacité/route ne leur donne de raison
      // de lire les admissions) — careCoordinationCanRead() restreint
      // au personnel clinique et à la réception.
      allow read: if canReadMedicalData(resource.data) ||
        careCoordinationCanRead(resource.data);
      allow create, update: if isAdmin() ||
        (canManageCare() && belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /receptionVisits/{docId} {
      // PARTIE E : même correctif que admissions. Correctif (section 18) :
      // careCoordinationCanRead() remplace belongsToSameEstablishment()
      // seule (excluait mal lab/pharmacist).
      allow read: if canReadMedicalData(resource.data) ||
        careCoordinationCanRead(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /emergencyCases/{docId} {
      // PARTIE E : même correctif que admissions. Correctif (section 18) :
      // careCoordinationCanRead() remplace belongsToSameEstablishment()
      // seule.
      allow read: if canReadMedicalData(resource.data) ||
        careCoordinationCanRead(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /maternityCases/{docId} {
      // PARTIE E : même correctif que admissions. Correctif (section 18) :
      // careCoordinationCanRead() remplace belongsToSameEstablishment()
      // seule.
      allow read: if canReadMedicalData(resource.data) ||
        careCoordinationCanRead(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /aiQueries/{docId} {
      // Historique des requêtes IA médicale : lecture réservée à
      // l'auteur et à l'admin (peut contenir du contexte clinique).
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() ||
        (signedIn() && belongsToSameEstablishment(request.resource.data) &&
         desktopWorkflowCanWrite(resolveHospitalId(request.resource.data)));
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{docId} {
      // Journal d'audit : création libre pour tout utilisateur
      // signé (traçabilité, y compris des tentatives bloquées par
      // abonnement), jamais modifiable après coup. Lecture : admin,
      // et personnel clinique vérifié — même précédent que
      // admissions/receptionVisits ci-dessus (rôle vérifié au niveau
      // règle, portée établissement appliquée côté requête client
      // via listByHospital). Nécessaire pour l'onglet "Historique des
      // accès" du dossier médical (MedicalRecordDesktop), réservé aux
      // rôles cliniques dans l'UI.
      // PARTIE E : remplace le "currentRoleIs('doctor') ||
      // currentRoleIs('nurse')" (accès à tout le journal, tous
      // établissements) par belongsToSameEstablishment.
      // Correctif (audit "workflows mobile/desktop", section 18) :
      // belongsToSameEstablishment() seule rouvrait ce journal (peut
      // contenir du contexte clinique) à lab/pharmacist/reception,
      // alors que l'onglet "Historique des accès" n'est jamais visible
      // pour ces rôles côté client (js/hospital-capabilities.js
      // RECORD_SECTIONS). isClinicalHospitalMember() restreint au
      // personnel clinique réellement concerné.
      allow read: if isAdmin() || isClinicalHospitalMember(resource.data);
      // Correctif (chantier "durcissement sans Cloud Functions") :
      // "if signedIn()" seul ne contraignait AUCUN champ — n'importe
      // quel utilisateur connecté pouvait créer une entrée d'audit au
      // nom d'un tiers (userId arbitraire). Un vrai journal
      // infalsifiable ET non-omissible nécessite un trigger serveur
      // (Cloud Function), donc le plan Blaze — hors de portée sur
      // Spark. Mitigation atteignable ici : quand le champ userId est
      // posé, il doit correspondre à l'auteur réel de la requête (ferme
      // la forge d'identité) ; absent, la création reste tolérée pour
      // ne pas casser les appelants existants qui ne le posent pas
      // encore. Ne ferme PAS l'omission volontaire d'un log (impossible
      // à forcer sans code serveur) — limite à garder honnête dans le
      // rapport.
      allow create: if signedIn() &&
        (request.resource.data.get('userId', null) == null ||
         request.resource.data.get('userId', null) == request.auth.uid);
      allow update, delete: if false;
    }

    /* ── Version manager : maintenance / version minimale ──
       Lecture publique (même non authentifié : le bandeau de
       maintenance doit rester visible avant connexion), écriture
       réservée à l'administrateur plateforme. */
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ── Transfert d'urgence inter-hôpitaux ─────────────
       Point 12 de la commande : l'hôpital destinataire n'a JAMAIS
       le droit de modifier les données médicales d'un autre hôpital.
       Seul l'hôpital source (créateur) peut modifier le statut du
       transfert ; le destinataire ne peut que LIRE, et faire
       progresser le statut via les actions dédiées (accepter,
       marquer en transit/arrivé) sans toucher au contenu médical
       (emergencyPacket reste figé après création — non modifiable
       par update, seul le statut/timestamps changent). */
    // Correctif P0/P1 (audit "workflows mobile/desktop", section 16) :
    // matrice de transitions de statut d'un transfert d'urgence —
    // alignée sur js/emergency-transfer.js STATUSES (requested/
    // accepted/in_transit/arrived/completed/cancelled, PAS les
    // libellés génériques rejected/closed d'un autre produit).
    // L'annulation reste possible tant que le transfert n'est pas
    // arrivé/terminé (cancelTransfer peut être appelé à tout moment
    // avant l'arrivée, sans validation client existante — la règle
    // serveur fixe donc ici la seule limite réelle).
    function emergencyTransferStatusTransitionOk(oldStatus, newStatus) {
      return oldStatus == newStatus ||
        (oldStatus == 'requested' && (newStatus == 'accepted' || newStatus == 'cancelled')) ||
        (oldStatus == 'accepted' && (newStatus == 'in_transit' || newStatus == 'cancelled')) ||
        (oldStatus == 'in_transit' && (newStatus == 'arrived' || newStatus == 'cancelled')) ||
        (oldStatus == 'arrived' && newStatus == 'completed');
    }

    match /emergencyTransfers/{transferId} {
      // PARTIE I : remplace le "signedIn()" trop large (tout utilisateur
      // connecté, y compris hors du transfert) par une vérification
      // réelle d'appartenance à l'hôpital source OU destinataire (ou
      // patient concerné), en plus de l'admin.
      allow read: if isAdmin() ||
        isHospitalMember(resource.data.fromHospitalId) ||
        isHospitalMember(resource.data.toHospitalId) ||
        isConcernedPatient(resource.data.patientId);
      // Correctif P0/P1 (section 16) : hospitalCanWriteFromDevice() ne
      // vérifie QUE l'abonnement/le type d'appareil, jamais
      // l'appartenance réelle — n'importe quel utilisateur connecté,
      // même sans lien avec fromHospitalId, pouvait créer un transfert
      // au nom de n'importe quel établissement. isHospitalMember()
      // ferme cette faille ; requestingDoctorId (déjà posé par
      // js/emergency-transfer.js createEmergencyTransfer, champ
      // existant — aucun nouveau champ requis côté client) doit
      // correspondre à l'auteur réel de l'écriture.
      // Correctif (audit "workflows mobile/desktop", section 13) : bug
      // confirmé — le helper canDecideTransfer() (ligne 99) existait
      // déjà mais n'était jamais utilisé ici. Un simple membre de
      // l'hôpital source (infirmier, réception, laborantin, pharmacien —
      // AUCUN n'a la capacité 'decide_transfer' côté client,
      // js/hospital-capabilities.js) pouvait donc, en posant
      // requestingDoctorId à son propre uid, créer un vrai transfert
      // d'urgence via une écriture Firestore directe, même si le bouton
      // JS restait cohérent avec sa capacité. Seul le rôle qui décide
      // réellement d'un transfert (médecin, ou admin hôpital) peut
      // désormais créer ce document.
      allow create: if isAdmin() ||
        (signedIn() &&
         canDecideTransfer() &&
         isHospitalMember(request.resource.data.get('fromHospitalId', null)) &&
         request.resource.data.get('requestingDoctorId', null) == request.auth.uid &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // Correctif P0/P1 (section 16) : "signedIn()" seul laissait
      // N'IMPORTE QUEL utilisateur connecté (aucun lien avec ce
      // transfert) faire progresser son statut du moment que les
      // champs figés ci-dessous restaient intacts. Restreint désormais
      // aux membres réels de l'hôpital source OU destinataire (seuls
      // acteurs légitimes, cf. js/emergency-transfer.js acceptTransfer/
      // startTransfer/markArrived/completeTransfer/cancelTransfer),
      // avec une matrice de transitions explicite et l'origine
      // (source, destination, patient, auteur) entièrement figée.
      allow update: if isAdmin() ||
        ((isHospitalMember(resource.data.fromHospitalId) || isHospitalMember(resource.data.toHospitalId)) &&
         request.resource.data.emergencyPacket == resource.data.emergencyPacket &&
         request.resource.data.fromHospitalId == resource.data.fromHospitalId &&
         request.resource.data.toHospitalId == resource.data.toHospitalId &&
         request.resource.data.patientId == resource.data.patientId &&
         request.resource.data.get('requestingDoctorId', null) == resource.data.get('requestingDoctorId', null) &&
         emergencyTransferStatusTransitionOk(resource.data.get('status', null), request.resource.data.get('status', null)));
      allow delete: if isAdmin();
    }

    match /medical_record_shares/{shareId} {
      // PARTIE I : lecture réellement réservée à l'hôpital source,
      // l'hôpital destinataire, le patient concerné, ou l'admin — le
      // "signedIn()" précédent laissait n'importe quel utilisateur
      // connecté lire n'importe quel partage, tiers inclus.
      allow read: if isAdmin() ||
        isHospitalMember(resource.data.fromHospitalId) ||
        isHospitalMember(resource.data.toHospitalId) ||
        isConcernedPatient(resource.data.patientId);
      // Correctif P0/P1 (audit "workflows mobile/desktop", section 16) :
      // même faille que emergencyTransfers — hospitalCanWriteFromDevice()
      // ne vérifie que l'abonnement, jamais l'appartenance réelle à
      // fromHospitalId. isHospitalMember() ferme ce cas (un partage ne
      // peut être créé qu'au nom d'un établissement dont on est
      // réellement membre actif).
      allow create: if isAdmin() ||
        (signedIn() &&
         isHospitalMember(request.resource.data.get('fromHospitalId', null)) &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // Seuls le statut/timestamps de révocation peuvent changer —
      // les sections partagées (allowedSections) et l'origine du
      // partage sont figées après création.
      // Correctif (chantier "durcissement sans Cloud Functions") :
      // "signedIn()" seul laissait N'IMPORTE QUEL utilisateur connecté
      // (un tiers sans aucun lien avec ce partage) faire progresser son
      // statut — restreint désormais exactement aux mêmes parties
      // légitimes que la règle "read" ci-dessus (l'hôpital source, le
      // destinataire qui approuve via js/hospital.js
      // approveIncomingShare, ou le patient concerné), jamais un tiers
      // quelconque.
      allow update: if isAdmin() ||
        ((isHospitalMember(resource.data.fromHospitalId) ||
          isHospitalMember(resource.data.toHospitalId) ||
          isConcernedPatient(resource.data.patientId)) &&
         request.resource.data.allowedSections == resource.data.allowedSections &&
         request.resource.data.fromHospitalId == resource.data.fromHospitalId &&
         request.resource.data.patientId == resource.data.patientId);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
