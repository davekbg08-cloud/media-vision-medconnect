rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasCurrentUserDoc() {
      return signedIn() && exists(currentUserDoc());
    }

    function currentRoleIs(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == role)
      );
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == 'admin')
      );
    }

    /* ── CAPACITÉS PAR RÔLE (miroir serveur de HospitalCapabilities) ──
       Le rôle est lu depuis users/{uid} (currentRoleIs) ou le token :
       il est VÉRIFIÉ, non déclaré par le client. Ces helpers permettent
       aux règles de refuser elles-mêmes une action que le rôle ne
       permet pas — même si le client contourne le JavaScript.
       Note : admin_hospital et lab n'ont pas de rôle mobile ; ils
       apparaissent ici pour le desktop. La source reste users/{uid}. */
    function hasRole(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (hasCurrentUserDoc() && get(currentUserDoc()).data.role == role)
      );
    }
    // 'hospital' = compte d'établissement authentifié (connexion
    // desktop). C'est l'identité Firebase que porte tout agent en
    // session desktop. Le rôle FIN de l'agent (médecin/labo/…) est
    // vérifié côté client via le staff de l'établissement ; le serveur
    // garantit ici que l'écriture émane d'un établissement authentifié.
    // Le compte doit être validé (status actif) — voir isActiveHospital.
    function isActiveHospital() {
      return signedIn() && hasCurrentUserDoc() &&
        get(currentUserDoc()).data.role == 'hospital' &&
        get(currentUserDoc()).data.status in ['active', 'approved'];
    }
    // Décider/valider un acte médical : médecin (ou admin plateforme/hôpital)
    function canDecideMedical() {
      return isAdmin() || hasRole('doctor') || hasRole('admin_hospital') || isActiveHospital();
    }
    // Prescrire : strictement médecin
    function canPrescribe() {
      return isAdmin() || hasRole('doctor') || isActiveHospital();
    }
    // Décider un transfert médical : médecin (ou admin hôpital)
    function canDecideTransfer() {
      return isAdmin() || hasRole('doctor') || hasRole('admin_hospital') || isActiveHospital();
    }
    // Admettre / sortir / gérer lits : personnel de soins
    function canManageCare() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') || hasRole('admin_hospital') || isActiveHospital();
    }
    // Saisir un résultat de labo : laborantin (ou médecin/admin)
    function canEnterLabResult() {
      return isAdmin() || hasRole('lab') || hasRole('doctor') || hasRole('admin_hospital') || isActiveHospital();
    }
    // Enregistrer une arrivée / créer patient à l'accueil : réception + soignants
    function canRegisterPatient() {
      return isAdmin() || hasRole('doctor') || hasRole('nurse') ||
             hasRole('reception') || hasRole('admin_hospital') || isActiveHospital();
    }

    /* ── Abonnement établissement (contrat mobile ↔ desktop) ──
       Aucun document subscriptions/{hospitalId} => traité comme
       "active" par défaut (rétro-compatibilité : ne bloque pas les
       établissements existants tant que l'abonnement n'a pas été
       explicitement configuré). */
    function subscriptionDoc(hospitalId) {
      return /databases/$(database)/documents/subscriptions/$(hospitalId);
    }
    function subscriptionStatus(hospitalId) {
      return hospitalId != null && exists(subscriptionDoc(hospitalId))
        ? get(subscriptionDoc(hospitalId)).data.status
        : 'active';
    }
    function hospitalSubscriptionOk(hospitalId) {
      return subscriptionStatus(hospitalId) in ['active', 'grace_period'];
    }
    // Utilisée telle quelle uniquement pour /patients : la création
    // de patient reste bloquée par abonnement expiré/suspendu quelle
    // que soit la plateforme (desktop ET mobile/PWA — confirmé
    // explicitement : c'est la seule action que le mobile bloque
    // aussi).
    function hospitalCanWrite(hospitalId) {
      return hospitalSubscriptionOk(hospitalId);
    }
    // Utilisée pour consultations/prescriptions/labRequests/
    // labResults/appointments/messages/hospitalMembers : le mobile/PWA
    // reste autorisé à écrire même hôpital expiré (le soin courant ne
    // doit jamais être coupé pour une facture desktop impayée) ; seul
    // le desktop est réellement bloqué. Le signal sourceDevice vient
    // du document envoyé par le client (voir note de risque résiduel
    // dans le rapport final : un client malveillant pourrait usurper
    // ce champ — accepté comme limite connue, pas de nouveau système
    // d'auth introduit pour ce chantier).
    // ⚠️ LIMITE DE SÉCURITÉ CONNUE — sourceDevice est DÉCLARÉ par le
    // client : un client desktop peut envoyer sourceDevice:'mobile'
    // pour contourner le blocage d'abonnement. Fermer réellement cette
    // faille exige un custom claim posé côté serveur (Cloud Function),
    // que les règles liraient via request.auth.token.deviceType au lieu
    // du champ du document. Tant que ce backend n'existe pas, le gating
    // desktop reste dissuasif mais non infalsifiable. NE PAS présenter
    // ce contrôle comme une sécurité forte.
    // Migration future : remplacer `deviceValue` par
    // `request.auth.token.deviceType` ici, sans toucher aux appelants.
    function hospitalCanWriteFromDevice(hospitalId, deviceValue) {
      return hospitalSubscriptionOk(hospitalId) || deviceValue != 'desktop';
    }
    // Le code applicatif écrit establishmentId (parfois hospital_id
    // en repli historique) — jamais un champ "hospitalId" littéral.
    // Ce helper évite de répéter ce repli dans chaque règle.
    function resolveHospitalId(data) {
      return data.establishmentId != null ? data.establishmentId
        : (data.hospital_id != null ? data.hospital_id
        : (data.hospitalId != null ? data.hospitalId : data.fromHospitalId));
    }

    function ownsUid(uid) {
      return signedIn() && uid == request.auth.uid;
    }

    function uidIn(listValue) {
      return signedIn() && listValue is list && request.auth.uid in listValue;
    }

    function ownsPatientData(data) {
      return signedIn() && (
        data.uid == request.auth.uid ||
        data.patientUid == request.auth.uid ||
        data.patient_uid == request.auth.uid ||
        data.ownerUid == request.auth.uid
      );
    }

    function doctorCanRead(data) {
      return currentRoleIs('doctor') && (
        data.created_by == request.auth.uid ||
        data.doctorUid == request.auth.uid ||
        data.doctor_uid == request.auth.uid ||
        uidIn(data.doctorUids) ||
        uidIn(data.authorizedDoctorUids)
      );
    }

    function nurseCanRead(data) {
      return currentRoleIs('nurse') && (
        data.nurseUid == request.auth.uid ||
        data.nurse_uid == request.auth.uid ||
        uidIn(data.nurseUids) ||
        uidIn(data.authorizedNurseUids)
      );
    }

    function pharmacyCanReadPrescription(data) {
      return currentRoleIs('pharmacist') && (
        data.pharmacyUid == request.auth.uid ||
        data.pharmacy_uid == request.auth.uid ||
        data.receivedByPharmacyUid == request.auth.uid ||
        uidIn(data.pharmacyUids)
      );
    }

    function canReadMedicalData(data) {
      return isAdmin() ||
        ownsPatientData(data) ||
        doctorCanRead(data) ||
        nurseCanRead(data);
    }

    function publicUserRole(role) {
      // 'hospital' : compte d'établissement (connexion desktop par
      // matricule). Auto-créé en statut 'pending', validé par l'admin
      // comme les autres inscriptions professionnelles.
      return role in ['patient', 'doctor', 'nurse', 'pharmacist', 'hospital'];
    }

    function hasNoSecretFields(data) {
      return !data.keys().hasAny(['admin', 'password', 'passwordHash']);
    }

    function visiblePharmacyProfile(data) {
      return data.role == 'pharmacist' &&
        data.isLocationVisible == true &&
        data.status in ['active', 'approved'];
    }

    function safeSelfUserCreate(uid) {
      return ownsUid(uid) &&
        request.resource.data.uid == uid &&
        publicUserRole(request.resource.data.role) &&
        request.resource.data.status == 'pending' &&
        hasNoSecretFields(request.resource.data);
    }

    function safeSelfUserUpdate(uid) {
      return ownsUid(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        hasNoSecretFields(request.resource.data);
    }

    match /users/{uid} {
      allow create: if isAdmin() || safeSelfUserCreate(uid);
      allow read: if isAdmin() ||
        ownsUid(uid) ||
        visiblePharmacyProfile(resource.data);
      allow update: if isAdmin() || safeSelfUserUpdate(uid);
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if canReadMedicalData(resource.data);
      // Création bloquée si abonnement expiré/suspendu — confirmé :
      // c'est la SEULE action que le mobile/PWA bloque aussi (voir
      // hospitalCanWrite, sans distinction de plateforme ici).
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse')) &&
         hospitalCanWrite(request.resource.data.establishmentId != null
           ? request.resource.data.establishmentId
           : request.resource.data.hospital_id));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data);
    }

    match /doctors/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'doctor' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin();
    }

    match /nurses/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'nurse' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin();
    }

    match /pharmacies/{uid} {
      allow read: if isAdmin() ||
        ownsUid(uid) ||
        (
          resource.data.isLocationVisible == true &&
          resource.data.status in ['active', 'approved']
        );
      allow create: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.uid == uid &&
          request.resource.data.role == 'pharmacist' &&
          request.resource.data.status == 'pending' &&
          hasNoSecretFields(request.resource.data)
        );
      allow update: if isAdmin() ||
        (
          ownsUid(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          hasNoSecretFields(request.resource.data)
        );
      allow delete: if isAdmin();
    }

    match /hospitals/{hospitalId} {
      allow read: if signedIn() && (
        resource.data.status in ['active', 'approved'] ||
        uidIn(resource.data.staffUids) ||
        resource.data.owner_uid == request.auth.uid ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    match /medical_records/{recordId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
      allow update, delete: if isAdmin() || doctorCanRead(resource.data);
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAdmin() ||
        ownsPatientData(resource.data) ||
        doctorCanRead(resource.data) ||
        pharmacyCanReadPrescription(resource.data);
      allow create: if isAdmin() ||
        (currentRoleIs('doctor') &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // La pharmacie ciblée peut toujours mettre à jour le statut
      // même abonnement expiré/suspendu (une ordonnance déjà envoyée
      // doit pouvoir être honorée) ; le médecin auteur reste soumis
      // à la même règle desktop/mobile que la création.
      allow update: if isAdmin() ||
        pharmacyCanReadPrescription(resource.data) ||
        (doctorCanRead(resource.data) &&
         hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        ((currentRoleIs('doctor') || currentRoleIs('nurse') || ownsPatientData(request.resource.data)) &&
         hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update, delete: if isAdmin() || doctorCanRead(resource.data) || ownsPatientData(resource.data);
    }

    match /notifications/{notificationId} {
      allow read, update: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.to_id == request.auth.uid ||
            resource.data.recipientUid == request.auth.uid ||
            resource.data.userUid == request.auth.uid
          )
        );
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /registration_requests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() ||
        (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /establishments/{establishmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    /* PARTIE G — trace/audit des documents médicaux par établissement.
       Lecture : admin, médecin auteur, ou tout utilisateur signé
       (cas réel : équipe de l'établissement) — l'écriture reste
       réservée à l'auteur ou à l'admin, jamais modifiable après coup. */
    match /establishment_documents/{documentId} {
      allow read: if isAdmin() || signedIn();
      allow create: if isAdmin() ||
        (signedIn() && request.resource.data.doctorUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /affiliation_requests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() ||
        (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /mc_accounts/{docId} {
      // Lecture ouverte : indispensable pour retrouver son compte
      // (numéro pro / ID patient) AVANT toute authentification.
      // Ne contient aucune donnée médicale — uniquement profil/accès.
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/mc_accounts/$(docId));
      allow update, delete: if isAdmin() || (signedIn() && request.auth.uid == docId);
    }

    match /mc_verified_doctors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_verified_pharms/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_verified_nurses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mc_consultations/{docId} {
      // Lecture alignée sur l'écriture (déjà role-wide ci-dessous) :
      // sans ça le listener global mc_consultations était rejeté en bloc.
      allow read: if currentRoleIs('doctor') || currentRoleIs('nurse') ||
        canReadMedicalData(resource.data);
      // Créer/valider une consultation = acte médical : médecin
      // uniquement (l'infirmier peut lire, pas créer). Verrouillage
      // serveur du contrôle de capacité côté client.
      allow write: if canDecideMedical();
    }

    match /mc_vaccinations/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
    }

    match /mc_lab_results/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse');
    }

    match /mc_medicines/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin() || currentRoleIs('pharmacist');
    }

    match /mc_sales/{docId} {
      allow read: if isAdmin() || currentRoleIs('pharmacist');
      allow write: if isAdmin() || currentRoleIs('pharmacist');
    }

    match /mc_consents/{docId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /mc_patients/{docId} {
      // Personnel clinique vérifié : nécessaire au listener global
      // mc_patients (fiches patient inaccessibles en bloc sinon).
      allow read: if currentRoleIs('doctor') || currentRoleIs('nurse') ||
        canReadMedicalData(resource.data);
      allow write: if isAdmin();
    }

    match /mc_prescriptions/{docId} {
      // Lecture élargie au personnel clinique vérifié : les listeners
      // globaux (et la vue établissement du médecin, et la vue
      // consentement de l'infirmière) sont des requêtes collection
      // entière, impossibles à satisfaire avec les seuls champs
      // par-document. Même précédent currentRoleIs que /labRequests ;
      // le consentement patient reste appliqué côté app (ACL).
      allow read: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse') ||
        ownsPatientData(resource.data) || pharmacyCanReadPrescription(resource.data);
      allow create: if isAdmin() || currentRoleIs('doctor');
      allow update: if isAdmin()
        || doctorCanRead(resource.data)
        || pharmacyCanReadPrescription(resource.data);
      allow delete: if isAdmin();
    }

    match /mc_appointments/{docId} {
      allow read: if canReadMedicalData(resource.data);
      allow write: if isAdmin();
    }

    match /mc_messages/{docId} {
      allow read, update: if isAdmin() || (signedIn() && resource.data.to_id == request.auth.uid);
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /mc_hospitals/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mc_affiliations/{docId} {
      allow read: if isAdmin() || (signedIn() && resource.data.requesterUid == request.auth.uid);
      allow write: if isAdmin();
    }

    /* ══════════════════════════════════════════════════
       CONTRAT D'ÉCHANGE MOBILE ↔ DESKTOP
       Chaque document porte hospitalId + createdByUid. L'écriture
       exige : membre signé, et abonnement actif/grace_period —
       vérifié côté serveur (hospitalCanWrite), pas seulement en JS.
       L'admin garde un accès de secours pour la maintenance.
    ══════════════════════════════════════════════════ */
    match /subscriptions/{hospitalId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /consultations/{docId} {
      allow read: if isAdmin() || canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /labRequests/{docId} {
      // Lecture : personnel clinique vérifié — indispensable pour la
      // liste établissement du desktop et pour le listener infirmier
      // mobile d'ExchangeBridge (requête hôpital-entier, impossible à
      // satisfaire avec canReadMedicalData seul). Même précédent
      // currentRoleIs que /admissions.
      allow read: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse') ||
        canReadMedicalData(resource.data);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /labResults/{docId} {
      allow read: if isAdmin() || canReadMedicalData(resource.data);
      // Saisir un résultat = capacité labo/médecin ET gating device.
      allow create: if isAdmin() ||
        (canEnterLabResult() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (canEnterLabResult() && hospitalCanWriteFromDevice(resolveHospitalId(resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /messages/{docId} {
      allow read: if isAdmin() ||
        (signedIn() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid));
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update: if isAdmin() ||
        (signedIn() && resource.data.toUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readStatus','readAt']));
      allow delete: if isAdmin();
    }

    match /hospitalMembers/{docId} {
      allow read: if isAdmin() || signedIn();
      allow create, update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    /* ── Bundle desktop hôpital (adapté) — beds/admissions/aiQueries ── */
    match /beds/{docId} {
      allow read: if isAdmin() || signedIn();
      allow create, update: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /admissions/{docId} {
      // Lecture : personnel clinique vérifié (précédent du projet
      // pour les données partagées au niveau établissement) +
      // patient concerné via canReadMedicalData si uid présent.
      allow read: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse') ||
        canReadMedicalData(resource.data);
      allow create, update: if isAdmin() ||
        (canManageCare() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /receptionVisits/{docId} {
      // File d'accueil : lecture par le personnel clinique vérifié
      // (même précédent que admissions).
      allow read: if isAdmin() || currentRoleIs('doctor') || currentRoleIs('nurse') ||
        canReadMedicalData(resource.data);
      allow create, update: if isAdmin() ||
        (canRegisterPatient() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow delete: if isAdmin();
    }

    match /aiQueries/{docId} {
      // Historique des requêtes IA médicale : lecture réservée à
      // l'auteur et à l'admin (peut contenir du contexte clinique).
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{docId} {
      // Journal d'audit : création libre pour tout utilisateur
      // signé (traçabilité, y compris des tentatives bloquées par
      // abonnement), jamais modifiable après coup, lecture admin
      // uniquement.
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    /* ── Transfert d'urgence inter-hôpitaux ─────────────
       Point 12 de la commande : l'hôpital destinataire n'a JAMAIS
       le droit de modifier les données médicales d'un autre hôpital.
       Seul l'hôpital source (créateur) peut modifier le statut du
       transfert ; le destinataire ne peut que LIRE, et faire
       progresser le statut via les actions dédiées (accepter,
       marquer en transit/arrivé) sans toucher au contenu médical
       (emergencyPacket reste figé après création — non modifiable
       par update, seul le statut/timestamps changent). */
    match /emergencyTransfers/{transferId} {
      allow read: if isAdmin() || signedIn();
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // Mise à jour de statut : l'hôpital source ou le destinataire
      // peuvent faire progresser le transfert, mais le paquet
      // médical (emergencyPacket) et l'origine ne peuvent jamais
      // être réécrits après création.
      allow update: if isAdmin() ||
        (signedIn() &&
         request.resource.data.emergencyPacket == resource.data.emergencyPacket &&
         request.resource.data.fromHospitalId == resource.data.fromHospitalId &&
         request.resource.data.patientId == resource.data.patientId);
      allow delete: if isAdmin();
    }

    match /medical_record_shares/{shareId} {
      // Lecture : hôpital source, hôpital destinataire, ou admin —
      // jamais un tiers hors du partage.
      allow read: if isAdmin() || signedIn();
      allow create: if isAdmin() ||
        (signedIn() && hospitalCanWriteFromDevice(resolveHospitalId(request.resource.data), request.resource.data.sourceDevice));
      // Seuls le statut/timestamps de révocation peuvent changer —
      // les sections partagées (allowedSections) et l'origine du
      // partage sont figées après création.
      allow update: if isAdmin() ||
        (signedIn() &&
         request.resource.data.allowedSections == resource.data.allowedSections &&
         request.resource.data.fromHospitalId == resource.data.fromHospitalId &&
         request.resource.data.patientId == resource.data.patientId);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
