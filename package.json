{
  "name": "medconnect",
  "version": "2.9.39",
  "description": "MedConnect — Application médicale universelle",
  "main": "index.html",
  "scripts": {
    "dev": "python -m http.server 8080",
    "test": "node --test tests/*.test.js",
    "lint": "eslint js sw.js",
    "e2e": "playwright test",
    "security:scan": "node scripts/check-secrets.mjs",
    "test:rules": "firebase emulators:exec --project demo-medconnect --only firestore \"node scripts/run-rules-tests.mjs\"",
    "sync:desktop-version": "node scripts/sync-desktop-version.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.5",
    "firebase": "^12.0.0",
    "firebase-tools": "^13.0.0"
  },
  "overrides": {
    "tar": "^7.5.19",
    "uuid": ">=11.1.1"
  }
}
